            gBirth   = regPatRequired('regPat_guardianBirthdate',      'Fecha de Nacimiento del Representante');
            gPhone   = regPatRequired('regPat_guardianPhone',          'Teléfono del Representante');
            gAddress = regPatRequired('regPat_guardianAddress',        'Dirección del Representante');
            gState   = regPatRequired('regPat_guardianStateId',        'Estado del Representante');
            gMun     = regPatRequired('regPat_guardianMunicipalityId', 'Municipio del Representante');
