@{
    Layout = null;
    bool sent = ViewBag.Sent == true;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restablecer Contraseña - Medycally</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family:'Inter',-apple-system,sans-serif;
            background:linear-gradient(135deg,#10b981 0%,#059669 100%);
            min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px;
        }
        .card-box {
            background:#fff; border-radius:20px; box-shadow:0 20px 60px rgba(0,0,0,.15);
            max-width:460px; width:100%; padding:48px;
        }
        .logo { display:flex; align-items:center; gap:10px; font-size:1.6rem; font-weight:700; color:#10b981; margin-bottom:2rem; }
        .form-control {
            padding:.75rem 1rem; border:1px solid #e2e8f0; border-radius:10px; font-size:1rem; transition:all .3s;
        }
        .form-control:focus { border-color:#10b981; box-shadow:0 0 0 3px rgba(16,185,129,.1); outline:none; }
        .input-wrap { position:relative; }
        .input-wrap i { position:absolute; left:1rem; top:50%; transform:translateY(-50%); color:#94a3b8; }
        .input-wrap .form-control { padding-left:2.75rem; }
        .btn-primary-med {
            width:100%; padding:.875rem; background:linear-gradient(135deg,#10b981,#059669);
            border:none; border-radius:10px; color:#fff; font-weight:600; font-size:1rem;
            cursor:pointer; transition:all .3s; box-shadow:0 4px 15px rgba(16,185,129,.3);
        }
        .btn-primary-med:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(16,185,129,.4); }
        .back-link { display:block; text-align:center; margin-top:1.5rem; color:#64748b; font-size:.9rem; }
        .back-link a { color:#10b981; font-weight:600; text-decoration:none; }
    </style>
</head>
<body>
    <div class="card-box">
        <div class="logo">
            <i class="fas fa-heartbeat"></i>
            <span>Medycally</span>
        </div>

        @if (sent)
        {
            <div style="text-align:center;">
                <div style="font-size:3.5rem;color:#10b981;margin-bottom:1.5rem;">
                    <i class="fas fa-envelope-circle-check"></i>
                </div>
                <h2 style="color:#1e293b;margin-bottom:.75rem;">Revisa tu correo</h2>
                <p style="color:#64748b;margin-bottom:2rem;">
                    Si el correo está registrado, recibirás un enlace para restablecer tu contraseña en los próximos minutos. El enlace expira en <strong>2 horas</strong>.
                </p>
                <a href="/Account/Login" class="btn-primary-med" style="text-decoration:none;display:inline-block;text-align:center;">
                    <i class="fas fa-arrow-left me-2"></i> Volver al inicio de sesión
                </a>
            </div>
        }
        else
        {
            <h2 style="color:#1e293b;margin-bottom:.5rem;">¿Olvidaste tu contraseña?</h2>
            <p style="color:#64748b;margin-bottom:2rem;">
                Ingresa tu correo y te enviaremos un enlace para restablecerla.
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center mb-3">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }

            <form method="post" asp-action="ForgotPassword">
                <div class="mb-4">
                    <label class="form-label fw-semibold" style="color:#1e293b;">Correo electrónico</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" name="email" class="form-control"
                               placeholder="tu@correo.com" required autofocus />
                    </div>
                </div>
                <button type="submit" class="btn-primary-med">
                    Enviar enlace <i class="fas fa-paper-plane ms-2"></i>
                </button>
            </form>

            <div class="back-link">
                <a href="/Account/Login"><i class="fas fa-arrow-left me-1"></i> Volver al inicio de sesión</a>
            </div>
        }
    </div>
</body>
</html>
