@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registrar Cita - Medycally</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary:   #10b981;
            --primary-d: #059669;
            --primary-dd:#047857;
            --dark:      #1e293b;
            --muted:     #6b7280;
            --border:    #e5e7eb;
            --bg:        #f0fdf4;
        }

        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 50%, #f8fafc 100%);
            min-height: 100vh;
        }

        /* ── PAGE LAYOUT ── */
        .wz-page { display: flex; flex-direction: column; min-height: 100vh; }

        /* ── HEADER ── */
        .wz-header {
            background: #fff;
            border-bottom: 1px solid var(--border);
            padding: .875rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 3px rgba(0,0,0,.05);
            position: sticky; top: 0; z-index: 100;
        }
        .wz-brand {
            color: #064e3b;
            text-decoration: none;
            font-size: 1.25rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .wz-brand i { color: var(--primary); font-size: 1.35rem; }
        .wz-brand:hover { color: #064e3b; }

        /* ── MAIN ── */
        .wz-main {
            flex: 1;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding: 2rem 1rem 3rem;
        }

        /* ── CARD ── */
        .wz-card {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 4px 6px rgba(0,0,0,.04), 0 10px 40px rgba(0,0,0,.08);
            width: 100%;
            max-width: 600px;
            overflow: hidden;
            transition: max-width .3s ease;
        }
        .wz-card.wide { max-width: 900px; }

        /* ── PROGRESS BAR ── */
        .wz-progress {
            height: 5px;
            background: #e5e7eb;
        }
        .wz-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--primary-d));
            transition: width .5s cubic-bezier(.4,0,.2,1);
            border-radius: 0 3px 3px 0;
        }

        /* ── STEPS ── */
        .wz-step { display: none; padding: 2rem; }
        .wz-step.active {
            display: block;
            animation: fadeStep .22s ease both;
        }

        @@keyframes fadeStep {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; transform: translateY(0);   }
        }

        /* ── TYPOGRAPHY ── */
        .step-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: .65rem;
        }
        .step-title i { color: var(--primary); }
        .step-sub {
            font-size: .9rem;
            color: #374151;
            font-weight: 500;
            margin-bottom: 1.25rem;
        }

        /* ── FORM CONTROLS ── */
        .form-label {
            font-weight: 600;
            color: #374151;
            font-size: .85rem;
            margin-bottom: .35rem;
        }
        .form-control, .form-select {
            border: 1.5px solid var(--border);
            border-radius: 9px;
            padding: .6rem 1rem;
            font-size: .9rem;
            color: var(--dark);
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(16,185,129,.15);
            outline: none;
        }
        .form-control.is-invalid, .form-select.is-invalid {
            border-color: #ef4444 !important;
        }
        textarea.form-control { resize: vertical; min-height: 90px; }

        /* ── BUTTONS ── */
        .btn-wz-next {
            background: linear-gradient(135deg, var(--primary), var(--primary-d));
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: .7rem 1.75rem;
            font-weight: 600;
            font-size: .9rem;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            cursor: pointer;
            transition: all .2s;
        }
        .btn-wz-next:hover {
            background: linear-gradient(135deg, var(--primary-d), var(--primary-dd));
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(16,185,129,.35);
            color: #fff;
        }
        .btn-wz-back {
            background: #fff;
            color: var(--muted);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            padding: .7rem 1.4rem;
            font-weight: 500;
            font-size: .88rem;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            cursor: pointer;
            transition: all .2s;
        }
        .btn-wz-back:hover {
            background: #f9fafb;
            border-color: #d1d5db;
            color: #374151;
        }
        .btn-wz-select {
            background: linear-gradient(135deg, var(--primary), var(--primary-d));
            color: #fff;
            border: none;
            border-radius: 8px;
            padding: .45rem 1.1rem;
            font-weight: 600;
            font-size: .8rem;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            cursor: pointer;
            transition: all .2s;
            white-space: nowrap;
        }
        .btn-wz-select:hover {
            background: linear-gradient(135deg, var(--primary-d), var(--primary-dd));
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(16,185,129,.3);
        }

        /* ── STEP NAV ── */
        .step-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.75rem;
            padding-top: 1.5rem;
            border-top: 1px solid #f3f4f6;
        }
        .step-nav.end { justify-content: flex-end; }

        /* ── RADIO OPTIONS ── */
        .wz-radio-group { display: flex; gap: 1rem; margin: .75rem 0 1rem; }
        .wz-radio-opt {
            flex: 1;
            border: 2px solid var(--border);
            border-radius: 13px;
            padding: 1rem 1.15rem;
            cursor: pointer;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: .75rem;
            font-weight: 500;
            color: #374151;
            user-select: none;
        }
        .wz-radio-opt:hover { border-color: var(--primary); background: #f0fdf4; }
        .wz-radio-opt.selected {
            border-color: var(--primary);
            background: #f0fdf4;
            color: #064e3b;
        }
        .wz-radio-opt input[type="radio"] {
            accent-color: var(--primary);
            width: 17px; height: 17px;
            flex-shrink: 0;
        }

        /* ── CLINIC CARD ── */
        #clinicsContainer { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin: 1rem 0; }
        #clinicsContainer.single { grid-template-columns: 1fr; max-width: 300px; margin: 1rem auto; }
        .clinic-wrap { perspective: 1200px; cursor: pointer; }
        .clinic-inner {
            border-radius: 16px;
            overflow: hidden;
            box-shadow:
                0 2px 4px  rgba(0,0,0,.07),
                0 8px 24px rgba(0,0,0,.11),
                0 24px 48px rgba(0,0,0,.07);
            transition: transform .4s ease, box-shadow .4s ease;
            transform-style: preserve-3d;
            background: #fff;
        }
        .clinic-wrap:hover .clinic-inner {
            transform: perspective(1200px) rotateX(4deg) rotateY(-2deg) translateY(-5px);
            box-shadow:
                0 8px 16px  rgba(0,0,0,.1),
                0 24px 52px rgba(0,0,0,.14),
                0 48px 80px rgba(0,0,0,.07);
        }
        .clinic-img-area {
            width: 100%; height: 210px;
            overflow: hidden;
            background: linear-gradient(180deg, #e0f2fe 0%, #bae6fd 100%);
            display: flex; align-items: center; justify-content: center;
        }
        .clinic-name-area {
            padding: 1.2rem 1.5rem 1.4rem;
            text-align: center;
            background: #fff;
        }
        .clinic-name {
            font-family: 'Playfair Display', Georgia, serif;
            font-size: 1.55rem;
            font-weight: 700;
            color: var(--dark);
            letter-spacing: .3px;
        }
        .clinic-tagline {
            font-size: .75rem;
            color: var(--muted);
            margin-top: .25rem;
            font-weight: 400;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        .clinic-hint {
            display: flex; align-items: center; justify-content: center;
            gap: .5rem; font-size: .8rem; color: var(--primary); font-weight: 500;
            margin-top: .85rem;
            animation: blink 2s ease-in-out infinite;
        }
        @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }

        /* ── PATIENT BADGE ── */
        .patient-badge {
            background: linear-gradient(135deg, #f0fdf4, #dcfce7);
            border: 1px solid #bbf7d0;
            border-radius: 12px;
            padding: .9rem 1.2rem;
            margin-bottom: 1.4rem;
            display: flex; align-items: center; gap: .75rem;
        }
        .patient-badge i { color: var(--primary); font-size: 1.6rem; flex-shrink: 0; }
        .patient-badge .pb-label { font-size: .7rem; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: .04em; }
        .patient-badge .pb-name  { font-weight: 700; color: #064e3b; font-size: 1rem; margin-bottom: .2rem; }
        .patient-badge .pb-meta  { font-size: .8rem; color: #374151; display: flex; flex-wrap: wrap; gap: .5rem; }
        .patient-badge .pb-chip  { background: #fff; border: 1px solid #bbf7d0; border-radius: 20px; padding: .1rem .55rem; font-size: .75rem; color: #065f46; font-weight: 500; }

        /* ── APPOINTMENT SLOTS ── */
        .slot-item {
            border: 1.5px solid var(--border);
            border-radius: 13px;
            padding: .9rem 1.1rem;
            margin-bottom: .7rem;
            display: flex; align-items: center;
            justify-content: space-between;
            gap: 1rem;
            transition: all .2s;
        }
        .slot-item:hover {
            border-color: var(--primary);
            background: #f0fdf4;
            box-shadow: 0 2px 10px rgba(16,185,129,.1);
        }
        .slot-doctor { font-weight: 600; color: var(--dark); font-size: .88rem; }
        .slot-meta   { font-size: .78rem; color: var(--muted); margin-top: .2rem; }
        .slot-badge  {
            display: inline-flex; align-items: center; gap: .25rem;
            font-size: .72rem; font-weight: 600;
            padding: .25rem .75rem; border-radius: 20px;
            white-space: nowrap;
        }
        .slot-badge.morning   { background: #fef3c7; color: #d97706; }
        .slot-badge.afternoon { background: #dbeafe; color: #2563eb; }

        /* ── CONFIRMATION ── */
        .confirm-check {
            width: 76px; height: 76px;
            background: #d1fae5;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1.5rem;
        }
        .confirm-check i { font-size: 2rem; color: var(--primary); }
        .confirm-table { font-size: .85rem; border-left: 4px solid var(--primary); }
        .confirm-table .k { font-weight: 600; color: #374151; }
        .confirm-table .v { color: var(--dark); }

        /* ── FOOTER ── */
        .wz-footer {
            background: #fff;
            border-top: 1px solid var(--border);
            padding: .9rem 2rem;
            text-align: center;
            font-size: .78rem;
            color: #9ca3af;
        }

        /* ── MOTIVO COMBO ── */
        .reason-combo { position: relative; }
        #reasonSearch { padding-right: 2.5rem; }
        .reason-dropdown {
            display: none;
            position: absolute;
            top: calc(100% + 4px);
            left: 0; right: 0;
            background: #fff;
            border: 1.5px solid var(--primary);
            border-radius: 9px;
            box-shadow: 0 4px 20px rgba(0,0,0,.13);
            z-index: 300;
            max-height: 220px;
            overflow-y: auto;
        }
        .reason-dropdown.open { display: block; }
        .reason-option {
            padding: .5rem 1rem;
            font-size: .88rem;
            color: var(--dark);
            cursor: pointer;
            transition: background .12s;
        }
        .reason-option:hover { background: #f0fdf4; color: #064e3b; }
        .reason-option.selected { background: #dcfce7; color: #064e3b; font-weight: 600; }
        .reason-no-results { padding: .55rem 1rem; font-size: .84rem; color: var(--muted); font-style: italic; }

        @@media (max-width: 576px) {
            .wz-radio-group { flex-direction: column; }
            .wz-main { padding: 1rem .5rem 2rem; }
            .wz-step { padding: 1.5rem 1.25rem; }
            .step-title { font-size: 1.15rem; }
        }
    </style>
</head>
<body>
<div class="wz-page">

    <!-- ╔══════════════════════════════╗ -->
    <!-- ║          HEADER              ║ -->
    <!-- ╚══════════════════════════════╝ -->
    <header class="wz-header">
            <a href="@Url.Action("Landing", "Home")" class="wz-brand">
            <i class="fas fa-heartbeat"></i>
            <span>Medycally</span>
        </a>
        <span class="d-none d-sm-flex align-items-center gap-2 text-muted" style="font-size:.82rem;">
            <i class="fas fa-lock text-success"></i> Conexión segura
        </span>
    </header>

    <!-- ╔══════════════════════════════╗ -->
    <!-- ║            MAIN              ║ -->
    <!-- ╚══════════════════════════════╝ -->
    <main class="wz-main">
        <div class="wz-card">

            <!-- Progress bar -->
            <div class="wz-progress">
                <div class="wz-progress-fill" id="progressFill" style="width:12%"></div>
            </div>

            <!-- ══════════════════════════════════════════
                 PASO 1 — Seleccionar especialidad
            ══════════════════════════════════════════ -->
            <div id="step-1" class="wz-step active">
                <h2 class="step-title">
                    <i class="fas fa-calendar-plus"></i> Registrar Cita
                </h2>
                <div class="mb-3">
                    <label class="form-label" for="specialtySelect">
                        <i class="fas fa-stethoscope me-1 text-success"></i>
                        Seleccione la especialidad
                    </label>
                    <select class="form-select form-select-lg" id="specialtySelect">
                        <option value="">Cargando especialidades...</option>
                    </select>
                </div>
                <div class="step-nav end">
                    <button type="button" class="btn-wz-next" id="btnS1Next">
                        Siguiente <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <!-- ══════════════════════════════════════════
                 PASO 2 — Tarjeta de la clínica
            ══════════════════════════════════════════ -->
            <div id="step-2" class="wz-step">
                <h2 class="step-title">
                    <i class="fas fa-hospital"></i> Clínicas Disponibles
                </h2>
                <p class="step-sub">Haga clic en una clínica para seleccionarla y continuar</p>

                <div id="clinicsContainer"></div>

                <div class="clinic-hint">
                    <i class="fas fa-hand-pointer"></i>
                    Haga clic en la clínica para continuar
                </div>

                <div class="step-nav">
                    <button type="button" class="btn-wz-back" onclick="document.querySelector('.wz-card').classList.remove('wide'); goBack('step-1')">
                        <i class="fas fa-arrow-left"></i> Regresar
                    </button>
                </div>
            </div>

            <!-- SVG clínica reutilizable (oculto) -->
            <template id="clinicSvgTemplate">
                <svg viewBox="0 0 500 220" xmlns="http://www.w3.org/2000/svg"
                     width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
                    <defs>
                        <linearGradient id="gSky" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"   stop-color="#bae6fd"/>
                            <stop offset="100%" stop-color="#e0f2fe"/>
                        </linearGradient>
                        <linearGradient id="gBldg" x1="0" y1="0" x2="1" y2="1">
                            <stop offset="0%"   stop-color="#ffffff"/>
                            <stop offset="100%" stop-color="#f0fdf4"/>
                        </linearGradient>
                        <linearGradient id="gRoof" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%"   stop-color="#10b981"/>
                            <stop offset="100%" stop-color="#059669"/>
                        </linearGradient>
                    </defs>
                    <rect width="500" height="220" fill="url(#gSky)"/>
                    <ellipse cx="80"  cy="38" rx="42" ry="20" fill="white" opacity=".82"/>
                    <ellipse cx="112" cy="32" rx="32" ry="18" fill="white" opacity=".82"/>
                    <ellipse cx="58"  cy="44" rx="26" ry="14" fill="white" opacity=".82"/>
                    <ellipse cx="380" cy="28" rx="38" ry="18" fill="white" opacity=".7"/>
                    <ellipse cx="415" cy="22" rx="28" ry="15" fill="white" opacity=".7"/>
                    <rect x="0" y="188" width="500" height="32" fill="#dcfce7"/>
                    <rect x="0" y="188" width="500" height="3"  fill="#10b981" opacity=".25"/>
                    <rect x="148" y="72" width="204" height="116" fill="url(#gBldg)" stroke="#e5e7eb" stroke-width="1.2"/>
                    <rect x="138" y="62" width="224" height="13" fill="url(#gRoof)" rx="3"/>
                    <rect x="165" y="88" width="36" height="28" fill="#bae6fd" rx="3" stroke="#93c5fd" stroke-width=".8"/>
                    <line x1="183" y1="88" x2="183" y2="116" stroke="#93c5fd" stroke-width=".6"/>
                    <line x1="165" y1="102" x2="201" y2="102" stroke="#93c5fd" stroke-width=".6"/>
                    <rect x="217" y="88" width="36" height="28" fill="#bae6fd" rx="3" stroke="#93c5fd" stroke-width=".8"/>
                    <line x1="235" y1="88" x2="235" y2="116" stroke="#93c5fd" stroke-width=".6"/>
                    <line x1="217" y1="102" x2="253" y2="102" stroke="#93c5fd" stroke-width=".6"/>
                    <rect x="269" y="88" width="36" height="28" fill="#bae6fd" rx="3" stroke="#93c5fd" stroke-width=".8"/>
                    <line x1="287" y1="88" x2="287" y2="116" stroke="#93c5fd" stroke-width=".6"/>
                    <line x1="269" y1="102" x2="305" y2="102" stroke="#93c5fd" stroke-width=".6"/>
                    <rect x="165" y="130" width="36" height="28" fill="#bae6fd" rx="3" stroke="#93c5fd" stroke-width=".8"/>
                    <line x1="183" y1="130" x2="183" y2="158" stroke="#93c5fd" stroke-width=".6"/>
                    <line x1="165" y1="144" x2="201" y2="144" stroke="#93c5fd" stroke-width=".6"/>
                    <rect x="217" y="130" width="36" height="28" fill="#bae6fd" rx="3" stroke="#93c5fd" stroke-width=".8"/>
                    <line x1="235" y1="130" x2="235" y2="158" stroke="#93c5fd" stroke-width=".6"/>
                    <line x1="217" y1="144" x2="253" y2="144" stroke="#93c5fd" stroke-width=".6"/>
                    <rect x="269" y="130" width="36" height="28" fill="#bae6fd" rx="3" stroke="#93c5fd" stroke-width=".8"/>
                    <line x1="287" y1="130" x2="287" y2="158" stroke="#93c5fd" stroke-width=".6"/>
                    <line x1="269" y1="144" x2="305" y2="144" stroke="#93c5fd" stroke-width=".6"/>
                    <rect x="214" y="160" width="72" height="28" fill="#059669" rx="3 3 0 0"/>
                    <rect x="219" y="164" width="27" height="24" fill="#bae6fd" rx="1.5"/>
                    <rect x="254" y="164" width="27" height="24" fill="#bae6fd" rx="1.5"/>
                    <line x1="232" y1="164" x2="232" y2="188" stroke="#7dd3fc" stroke-width=".7"/>
                    <line x1="267" y1="164" x2="267" y2="188" stroke="#7dd3fc" stroke-width=".7"/>
                    <rect x="206" y="184" width="88" height="5" fill="#d1fae5" rx="1.5"/>
                    <rect x="62" y="98" width="86" height="90" fill="url(#gBldg)" stroke="#e5e7eb" stroke-width="1"/>
                    <rect x="57" y="90" width="96" height="11" fill="url(#gRoof)" rx="2"/>
                    <rect x="74" y="112" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="107" y="112" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="74" y="142" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="107" y="142" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="352" y="98" width="86" height="90" fill="url(#gBldg)" stroke="#e5e7eb" stroke-width="1"/>
                    <rect x="347" y="90" width="96" height="11" fill="url(#gRoof)" rx="2"/>
                    <rect x="363" y="112" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="396" y="112" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="363" y="142" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="396" y="142" width="25" height="20" fill="#bae6fd" rx="2" stroke="#93c5fd" stroke-width=".7"/>
                    <rect x="242" y="18" width="16" height="36" fill="#ef4444" rx="3"/>
                    <rect x="230" y="29" width="40" height="14" fill="#ef4444" rx="3"/>
