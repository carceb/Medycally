/* ================================================================
   PASO 7 — Slots de cita
================================================================ */
async function renderSlots() {
    const container = document.getElementById('slotsList');
    container.innerHTML = '<p class="text-muted text-center py-3"><i class="fas fa-spinner fa-spin me-2"></i>Cargando horarios...</p>';

    let schedules;
    try {
        const resp = await fetch(`/Appointment/GetScheduleByClinicAndSpecialty?clinicId=${state.clinicId}&specialtyId=${state.specialtyId}`);
        schedules = await resp.json();
    } catch {
        container.innerHTML = '<p class="text-danger text-center py-3">Error al cargar los horarios.</p>';
        return;
    }

    if (!schedules.length) {
        container.innerHTML = '<p class="text-muted text-center py-3">No hay horarios disponibles para esta clínica y especialidad.</p>';
        return;
    }

    // SQL Server DayOfWeek: 1=domingo, 2=lunes, ..., 7=sábado → JS getDay(): 0=domingo, ..., 6=sábado
    const now = new Date();
    const today = new Date(now);
    today.setHours(0, 0, 0, 0);

    window._slots = [];
    container.innerHTML = '';

    schedules.forEach((s, idx) => {
        const targetJsDay = s.dayOfWeek;
        const d = new Date(today);
        // Si hoy es el día del horario, verificar si la hora de inicio ya pasó
        if (d.getDay() === targetJsDay) {
            const startHourToday = parseInt(s.startTime);
            const startMinToday = parseInt((s.startTime.split(':')[1]) || '0');
            const scheduleMinutes = startHourToday * 60 + startMinToday;
            const nowMinutes = now.getHours() * 60 + now.getMinutes();
            // Si el horario ya pasó, ir a la próxima semana
            if (nowMinutes >= scheduleMinutes) {
                d.setDate(d.getDate() + 7);
            }
        } else {
            // Buscar el próximo día que coincida (partiendo de mañana)
            d.setDate(d.getDate() + 1);
            while (d.getDay() !== targetJsDay) d.setDate(d.getDate() + 1);
        }

        const startHour = parseInt(s.startTime);
        const isMorning = startHour < 12;
        const slot = {
            doctor            : s.doctorName || '—',
            day               : s.dayName,
            date              : `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()}`,
            dateISO           : `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`,
            startTime         : s.startTime,
            shift             : isMorning ? 'Mañana' : 'Tarde',
            time              : `${s.startTimeFormatted} – ${s.endTimeFormatted}`,
            specialtyDoctorId : s.specialtyDoctorId
        };
        window._slots.push(slot);

        const div = document.createElement('div');
        div.className = 'slot-item';
        div.innerHTML = `
            <div style="flex:1;min-width:0;">
                <div class="slot-doctor">
                    <i class="fas fa-user-md text-success me-1"></i>${slot.doctor}
                </div>
                <div class="slot-meta">
                    <i class="fas fa-calendar-alt me-1"></i>${slot.day}, ${slot.date}
                    &nbsp;&bull;&nbsp;
                    <i class="fas fa-clock me-1"></i>${slot.time}
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <span class="slot-badge ${isMorning ? 'morning' : 'afternoon'}">
                    <i class="fas ${isMorning ? 'fa-sun' : 'fa-moon'}"></i> ${slot.shift}
                </span>
                <button class="btn-wz-select" onclick="selectSlot(${idx})">
                    <i class="fas fa-check"></i> Seleccionar
                </button>
            </div>`;
        container.appendChild(div);
    });
}

function calcAge(dateStr) {
    const birth = new Date(dateStr);
    const today = new Date();
    let age = today.getFullYear() - birth.getFullYear();
    const m = today.getMonth() - birth.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
    return age < 0 ? 0 : age;
}

function selectSlot(idx) {
    const s = window._slots[idx];
    state.selectedSlot = s;
    document.getElementById('confirmDetails').innerHTML = `
