@{
    ViewData["Title"] = "Atención Médica";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="fas fa-stethoscope me-2 text-primary"></i>Cola de Atención</h4>
        <small class="text-muted" id="clinicLabel">Cargando clínica...</small>
    </div>
    <div class="d-flex align-items-center gap-2">
        <input type="date" id="queueDate" class="form-control form-control-sm" style="width:160px" />
        <button type="button" class="btn btn-outline-primary btn-sm" onclick="loadQueue()">
            <i class="fas fa-sync-alt me-1"></i>Actualizar
        </button>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4" id="statsRow" style="display:none">
    <div class="col-4">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="fs-4 fw-bold text-primary" id="statTotal">0</div>
            <small class="text-muted">Total</small>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="fs-4 fw-bold text-success" id="statConfirmed">0</div>
            <small class="text-muted">Confirmados</small>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 shadow-sm text-center py-2">
            <div class="fs-4 fw-bold text-info" id="statInAttention">0</div>
            <small class="text-muted">En Atención</small>
        </div>
    </div>
</div>

<div id="queueContainer">
    <div class="text-center py-5 text-muted">
        <i class="fas fa-spinner fa-spin fa-2x mb-2"></i>
        <div>Cargando cola de pacientes...</div>
    </div>
</div>

<style>
    .queue-card {
        background: #fff; border: 1px solid #e9ecef; border-radius: 10px;
        padding: 1rem 1.25rem; margin-bottom: .75rem;
        display: flex; align-items: center; gap: 1rem; transition: box-shadow .15s;
    }
    .queue-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,.08); }
    .queue-card.status-in-attention { border-left: 4px solid #0dcaf0; background: #f0fbff; }
    .queue-card.status-confirmed    { border-left: 4px solid #198754; }
    .queue-time {
        min-width: 60px; text-align: center; font-size: 1.15rem;
        font-weight: 700; color: #495057; line-height: 1.1;
    }
    .queue-time small { font-size: .65rem; font-weight: 400; color: #6c757d; display: block; }
    .queue-info { flex: 1; min-width: 0; }
    .queue-patient-name { font-weight: 600; font-size: 1rem; }
    .queue-meta { font-size: .8rem; color: #6c757d; }
    .queue-symptoms {
        font-size: .78rem; color: #495057; margin-top: 3px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px;
    }
    .badge-confirmed    { background: #d1e7dd; color: #0a3622; }
    .badge-in-attention { background: #cff4fc; color: #055160; }
    .empty-queue { text-align: center; padding: 3rem 1rem; color: #6c757d; }
    .empty-queue i { font-size: 3rem; margin-bottom: 1rem; opacity: .3; }
</style>

@section Scripts {
<script>
    const TODAY = new Date().toISOString().substring(0, 10);
    document.getElementById('queueDate').value = TODAY;

    let activeClinicId   = parseInt(localStorage.getItem('activeClinicId') || '1');
    let activeClinicName = '';
    let queueData        = [];

    window.addEventListener('clinicChanged', e => {
        activeClinicId   = e.detail.clinicId;
        activeClinicName = e.detail.clinicName ?? '';
        updateClinicLabel();
        loadQueue();
    });

    function updateClinicLabel() {
        const name = activeClinicName || localStorage.getItem('medycallyActiveName') || '';
        document.getElementById('clinicLabel').textContent = name || `Clínica ID ${activeClinicId}`;
    }

    async function loadQueue() {
        const date = document.getElementById('queueDate').value || TODAY;
        document.getElementById('queueContainer').innerHTML = `
            <div class="text-center py-5 text-muted">
                <i class="fas fa-spinner fa-spin fa-2x mb-2"></i>
                <div>Cargando cola... (Clínica ${activeClinicId}, fecha ${date})</div>
            </div>`;
        try {
            const res = await fetch(`/Medical/GetQueue?clinicId=${activeClinicId}&date=${date}`);
            if (!res.ok) throw new Error(`Error ${res.status}`);
            queueData = await res.json();
            renderQueue();
        } catch (e) {
            document.getElementById('queueContainer').innerHTML =
                `<div class="alert alert-danger"><i class="fas fa-exclamation-circle me-2"></i>${e.message}</div>`;
        }
    }

    function renderQueue() {
        const container   = document.getElementById('queueContainer');
        const inAttention = queueData.filter(q => q.appointmentStatusId === 4);
        const confirmed   = queueData.filter(q => q.appointmentStatusId === 2);

        document.getElementById('statTotal').textContent       = queueData.length;
        document.getElementById('statConfirmed').textContent   = confirmed.length + inAttention.length;
        document.getElementById('statInAttention').textContent = inAttention.length;
        document.getElementById('statsRow').style.display      = queueData.length ? '' : 'none';

        if (queueData.length === 0) {
            const date = document.getElementById('queueDate').value || TODAY;
            container.innerHTML = `
                <div class="empty-queue">
                    <i class="fas fa-calendar-times"></i>
                    <div class="fs-5 mb-1">Sin pacientes en cola</div>
                    <small>No hay citas confirmadas para la fecha <strong>${date}</strong>
                    en la clínica ID <strong>${activeClinicId}</strong>.</small>
                </div>`;
            return;
        }

        const sorted = [...inAttention, ...confirmed];

        container.innerHTML = sorted.map(q => {
            const isInAtt   = q.appointmentStatusId === 4;
            const cardClass = isInAtt ? 'status-in-attention' : 'status-confirmed';

            const statusBadge = isInAtt
                ? `<span class="badge badge-in-attention"><i class="fas fa-user-clock me-1"></i>En Atención</span>`
                : `<span class="badge badge-confirmed"><i class="fas fa-check-circle me-1"></i>Confirmado</span>`;

            const idNum    = q.patientIdNumber > 0 ? `V-${q.patientIdNumber}` : 'Sin cédula';
            const symptoms = q.symptoms
                ? `<div class="queue-symptoms"><i class="fas fa-comment-medical me-1"></i>${escapeHtml(q.symptoms)}</div>`
                : '';
            const reason = q.reasonName
                ? `<span class="me-2"><i class="fas fa-tag me-1"></i>${escapeHtml(q.reasonName)}</span>`
                : '';

            const btnLabel  = isInAtt ? 'Continuar' : 'Atender';
            const btnAttend = `<button type="button" class="btn btn-sm ${isInAtt ? 'btn-info' : 'btn-primary'} px-3"
                                       onclick="attendPatient(${q.appointmentId}, ${q.appointmentStatusId})">
                                   <i class="fas fa-user-check me-1"></i>${btnLabel}
                               </button>`;

            return `
            <div class="queue-card ${cardClass}">
                <div class="queue-time">
                    ${escapeHtml(q.appointmentTime ?? '--:--')}
                    <small>hrs</small>
                </div>
                <div class="queue-info">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="queue-patient-name">${escapeHtml(q.patientName ?? '')}</span>
                        ${statusBadge}
                    </div>
                    <div class="queue-meta mt-1">
                        <span class="me-2"><i class="fas fa-id-card me-1"></i>${idNum}</span>
                        <span class="me-2"><i class="fas fa-birthday-cake me-1"></i>${q.patientAge} años</span>
                        <span class="me-2"><i class="fas fa-stethoscope me-1"></i>${escapeHtml(q.specialtyName ?? '')}</span>
                        <span><i class="fas fa-user-md me-1"></i>${escapeHtml(q.doctorName ?? '')}</span>
                    </div>
                    <div class="queue-meta mt-1">${reason}</div>
                    ${symptoms}
                </div>
                <div class="ms-auto text-end">
                    ${btnAttend}
                </div>
            </div>`;
        }).join('');
    }

    async function attendPatient(appointmentId, statusId) {
        if (statusId === 4) {
            window.location.href = `/Medical/Patient/${appointmentId}`;
            return;
        }
        try {
            const res = await fetch('/Medical/StartAttention', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(appointmentId)
            });
            if (!res.ok) throw new Error('No se pudo iniciar la atención.');
            window.location.href = `/Medical/Patient/${appointmentId}`;
        } catch (e) { alert(e.message); }
    }

    function escapeHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    (function init() {
        updateClinicLabel();
        const cached = localStorage.getItem('medycallyClinicsV2');
        if (cached) {
            try {
                const clinics = JSON.parse(cached);
                const c = clinics.find(x => x.ClinicId === activeClinicId);
                if (c) {
                    activeClinicName = (c.ClinicTypeName ? c.ClinicTypeName + ' ' : '') + c.ClinicName;
                    updateClinicLabel();
                }
            } catch { }
        }
        loadQueue();
    })();
</script>
}
