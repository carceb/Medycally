function renderReasonOptions(filter) {
    const dropdown = document.getElementById('reasonDropdown');
    const q = (filter || '').toLowerCase().trim();
    const list = q ? allReasons.filter(r => r.reasonName.toLowerCase().includes(q.toLowerCase())) : allReasons;
    if (!list.length) {
