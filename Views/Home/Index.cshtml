        body.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>';
        modal.show();

        if (!isRegistered) {
            fetch(`/Home/GetAppointmentDetail?appointmentId=${appointmentId}`)
                .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e.message ?? 'Error')))
                .then(d => { body.innerHTML = buildDetailHtml(d); })
                .catch(msg => {
                    body.innerHTML = `<div class="alert alert-danger">${escHtml(typeof msg === 'string' ? msg : 'Error al cargar la cita.')}</div>`;
                });
            return;
        }

        try {
            const res  = await fetch(`/Home/GetPatientDetail?appointmentId=${appointmentId}`);
            const data = await res.json();
            body.innerHTML = buildPatientDetailHtml(data);
        } catch {
            body.innerHTML = '<div class="alert alert-danger">Error al cargar los datos del paciente.</div>';
        }
    }

    function buildPatientDetailHtml(d) {
        const idNum    = d.patientIdNumber ? `V-${escHtml(String(d.patientIdNumber))}` : '—';
        const phone    = d.patientMainPhone > 0 ? String(d.patientMainPhone) : '—';
        const address  = d.patientAddress  || '—';
        const location = [d.municipalityName, d.stateName].filter(Boolean).join(', ') || '—';

        let html = `
        <div class="mb-2">
            <div class="fw-bold fs-6 mb-2">${escHtml(d.patientName ?? '—')}
                ${d.isMinor ? '<span class="badge bg-warning text-dark ms-1">Menor</span>' : ''}
            </div>
            <table class="table table-sm table-borderless mb-0 small">
                <tr><td class="text-muted pe-3" style="width:110px">Cédula</td><td>${idNum}</td></tr>
                ${d.age > 0 ? `<tr><td class="text-muted pe-3">Edad</td><td>${d.age} años</td></tr>` : ''}
                ${d.sexName ? `<tr><td class="text-muted pe-3">Sexo</td><td>${escHtml(d.sexName)}</td></tr>` : ''}
                ${d.patientBirthdateDisplay ? `<tr><td class="text-muted pe-3">Nacimiento</td><td>${escHtml(d.patientBirthdateDisplay)}</td></tr>` : ''}
                <tr><td class="text-muted pe-3">Teléfono</td><td>${escHtml(phone)}</td></tr>
                ${location !== '—' ? `<tr><td class="text-muted pe-3">Ubicación</td><td>${escHtml(location)}</td></tr>` : ''}
                ${address !== '—' ? `<tr><td class="text-muted pe-3">Dirección</td><td>${escHtml(address)}</td></tr>` : ''}
            </table>
        </div>`;

        if (d.isMinor && d.guardianName) {
            html += `
        <hr class="my-2"/>
        <div class="small text-muted mb-1"><i class="fas fa-user-shield me-1"></i>Representante</div>
        <div class="fw-semibold">${escHtml(d.guardianName)}</div>
        ${d.relationshipName ? `<div class="small text-muted">${escHtml(d.relationshipName)}</div>` : ''}
        ${d.guardianIdNumber ? `<div class="small"><i class="fas fa-id-card me-1 text-muted"></i>V-${escHtml(d.guardianIdNumber)}</div>` : ''}
        ${d.guardianPhone    ? `<div class="small"><i class="fas fa-phone me-1 text-muted"></i>${escHtml(d.guardianPhone)}</div>` : ''}`;
        }

        return html;
    }

    function openAppointmentDetail(appointmentId) {
        const body  = document.getElementById('appointmentDetailBody');
        const modal = new bootstrap.Modal(document.getElementById('appointmentDetailModal'));
        body.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>';
        modal.show();

        fetch(`/Home/GetAppointmentDetail?appointmentId=${appointmentId}`)
            .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e.message ?? 'Error')))
            .then(d => { body.innerHTML = buildDetailHtml(d); })
            .catch(msg => {
                body.innerHTML = `<div class="alert alert-danger">${escHtml(typeof msg === 'string' ? msg : 'Error al cargar la cita.')}</div>`;
            });
    }

    function buildDetailHtml(d) {
        const isMinor   = d.patientTypeId === 2;
        const fmt       = v => escHtml(v ?? '—');
        const fmtDate   = v => v ? new Date(v).toLocaleDateString('es-VE', { day:'2-digit', month:'2-digit', year:'numeric' }) : '—';
        const fmtNum    = v => (v && v !== 0) ? String(v) : '—';
        const calcAgeFrom = dateStr => {
            if (!dateStr) return null;
            const birth = new Date(dateStr), today = new Date();
            let age = today.getFullYear() - birth.getFullYear();
            if (today < new Date(today.getFullYear(), birth.getMonth(), birth.getDate())) age--;
            return age;
        };
        const fmtAge = (storedAge, birthDate) => {
            if (storedAge > 0) return storedAge + ' años';
            const calc = calcAgeFrom(birthDate);
            return calc !== null ? calc + ' años' : '—';
        };
        const STATUS_LABELS = { 1: 'Pendiente', 2: 'Confirmada', 3: 'Cancelada' };
        const STATUS_BADGE  = { 1: 'warning', 2: 'success', 3: 'danger' };

        let html = `
        <div class="detail-section-title">Información de la Cita</div>
        <div class="detail-grid">
            <span class="label">N° de Cita</span>   <span class="value">#${d.appointmentId}</span>
            <span class="label">Clínica</span>       <span class="value">${fmt(d.clinicName)}</span>
            <span class="label">Especialidad</span>  <span class="value">${fmt(d.specialtyName)}</span>
            <span class="label">Médico</span>        <span class="value">${fmt(d.doctorName)}</span>
            <span class="label">Fecha</span>         <span class="value">${fmtDate(d.appointmentDate)}</span>
            <span class="label">Hora</span>          <span class="value">${fmt(d.appointmentTime)}</span>
            <span class="label">Motivo</span>        <span class="value">${fmt(d.reasonName)}</span>
            <span class="label">Síntomas</span>      <span class="value">${fmt(d.symptoms)}</span>
            <span class="label">Estatus</span>       <span class="value"><span class="badge bg-${STATUS_BADGE[d.appointmentStatusId] ?? 'secondary'}">${STATUS_LABELS[d.appointmentStatusId] ?? fmt(d.appointmentStatusName)}</span></span>
        </div>
        <hr class="detail-divider">`;

        if (isMinor) {
            html += `
        <div class="detail-section-title"><i class="fas fa-child me-1"></i>Datos del Menor</div>
        <div class="detail-grid">
            <span class="label">Nombre</span>            <span class="value">${fmt(d.patientName)}</span>
            <span class="label">Sexo</span>              <span class="value">${fmt(d.patientSexName)}</span>
            <span class="label">Edad</span>              <span class="value">${fmtAge(d.patientAge, d.patientBirthDate)}</span>
            <span class="label">Fecha de Nacimiento</span><span class="value">${fmtDate(d.patientBirthDate)}</span>
        </div>
        <hr class="detail-divider">
        <div class="detail-section-title"><i class="fas fa-user-shield me-1"></i>Datos del Representante</div>
        <div class="detail-grid">
            <span class="label">Nombre</span>            <span class="value">${fmt(d.childGuardianName)}</span>
            <span class="label">Cédula</span>            <span class="value">${fmtNum(d.childGuardianIdNumber)}</span>
            <span class="label">Parentesco</span>        <span class="value">${fmt(d.relationshipName)}</span>
            <span class="label">Sexo</span>              <span class="value">${fmt(d.childGuardianSexName)}</span>
            <span class="label">Fecha de Nacimiento</span><span class="value">${fmtDate(d.childGuardianBirthDate)}</span>
            <span class="label">Teléfono</span>          <span class="value">${fmt(d.childGuardianPhone)}</span>
            <span class="label">Dirección</span>         <span class="value">${fmt(d.childGuardianAddress)}</span>
            <span class="label">Estado</span>            <span class="value">${fmt(d.childGuardianStateName)}</span>
        </div>`;
        } else {
            html += `
        <div class="detail-section-title"><i class="fas fa-user me-1"></i>Datos del Paciente</div>
        <div class="detail-grid">
            <span class="label">Nombre</span>            <span class="value">${fmt(d.patientName)}</span>
            <span class="label">Cédula</span>            <span class="value">${fmtNum(d.patientIdNumber)}</span>
            <span class="label">Sexo</span>              <span class="value">${fmt(d.patientSexName)}</span>
            <span class="label">Edad</span>              <span class="value">${fmtAge(d.patientAge, d.patientBirthDate)}</span>
            <span class="label">Fecha de Nacimiento</span><span class="value">${fmtDate(d.patientBirthDate)}</span>
            <span class="label">Teléfono</span>          <span class="value">${fmt(d.patientPhone)}</span>
            <span class="label">Dirección</span>         <span class="value">${fmt(d.patientAddress)}</span>
            <span class="label">Estado</span>            <span class="value">${fmt(d.patientStateName)}</span>
        </div>`;
        }

        return html;
    }
</script>
}
