@model List<Medycally.Models.PatientModel>
@{
    ViewData["Title"] = "Pacientes";
    var sexes          = ViewBag.Sexes          as List<Medycally.Models.SexModel>          ?? [];
    var states         = ViewBag.States         as List<Medycally.Models.GeographyModel>    ?? [];
    var municipalities = ViewBag.Municipalities as List<Medycally.Models.GeographyModel>    ?? [];
    var relationships  = ViewBag.Relationships  as List<Medycally.Models.RelationshipModel> ?? [];
    var patPerms       = Permissions.GetPermissions(User, "/Patient/Index");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Pacientes</h4>
    @if (patPerms.CanCreate)
    {
        <button class="btn btn-primary" onclick="openModal()">
            <i class="fas fa-plus me-1"></i> Nuevo Paciente
        </button>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text text-muted"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" id="searchInput"
                           placeholder="Buscar por nombre, cédula, teléfono..."
                           oninput="applyFilters()" />
                    <button class="btn btn-outline-secondary" type="button" onclick="clearSearch()" title="Limpiar">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Cédula</th>
                        <th>Edad</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th>Familia</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody id="patientBody"></tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted" id="paginationInfo"></small>
            <nav>
                <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
            </nav>
        </div>

    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     Add / Edit Patient Modal
     ═══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="patientModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Nuevo Paciente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="patientId" value="0" />
                <input type="hidden" id="guardianPatientId" value="0" />

                <!-- Type selector -->
                <div id="patientTypeGroup" class="mb-4">
                    <label class="form-label fw-semibold mb-2">Tipo de paciente</label>
                    <div class="d-flex gap-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="patientType" id="typeAdult"
                                   value="adult" onchange="onPatientTypeChange('adult')" />
                            <label class="form-check-label" for="typeAdult">
                                <i class="fas fa-user me-1 text-primary"></i> Adulto
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="patientType" id="typeMinor"
                                   value="minor" onchange="onPatientTypeChange('minor')" />
                            <label class="form-check-label" for="typeMinor">
                                <i class="fas fa-child me-1 text-success"></i> Menor de edad
                            </label>
                        </div>
                    </div>
                    <div class="invalid-feedback d-block" id="typeError" style="display:none!important"></div>
                </div>

                <!-- ─── Adult Section ─── -->
                <div id="adultSection" class="d-none">
                    <h6 class="text-muted mb-3">Datos Personales</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label class="form-label">Nombre completo <span class="text-danger">*</span></label>
                            <input type="text" class="form-control pat-text" id="patientName" maxlength="150" />
                            <div class="invalid-feedback" id="nameError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sexo <span class="text-danger">*</span></label>
                            <select class="form-select" id="patientSexId">
                                <option value="0">— Seleccionar —</option>
                                @foreach (var s in sexes)
                                {
                                    <option value="@s.SexId">@s.SexName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="sexError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cédula <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="patientIdNumber" maxlength="9"
                                   inputmode="numeric" placeholder="Ej: 12345678" />
                            <div class="invalid-feedback" id="cedulaError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fecha de nacimiento <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="patientBirthdate" />
                            <div class="invalid-feedback" id="birthdateError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Teléfono <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="patientMainPhone" maxlength="15"
                                   inputmode="numeric" placeholder="Ej: 04141234567" />
                            <div class="invalid-feedback" id="phoneError"></div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Correo electrónico <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="patientEmail" maxlength="150"
                                   placeholder="nombre@correo.com" />
                            <div class="invalid-feedback" id="emailError"></div>
                        </div>
                    </div>
                    <h6 class="text-muted mb-3">Ubicación</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Estado</label>
                            <select class="form-select" id="patientStateId"
                                    onchange="loadMunicipalities(this.value, 0)">
                                <option value="0">— Seleccionar —</option>
                                @foreach (var st in states)
                                {
                                    <option value="@st.StateId">@st.StateName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Municipio</label>
                            <select class="form-select" id="patientMunicipalityId">
                                <option value="0">— Seleccionar estado primero —</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Dirección</label>
                            <input type="text" class="form-control pat-text" id="patientAddress" maxlength="300" />
                        </div>
                    </div>
                </div>

                <!-- ─── Minor Section ─── -->
                <div id="minorSection" class="d-none">
                    <h6 class="fw-semibold mb-3">
                        <i class="fas fa-child text-success me-1"></i> Datos del Menor
                    </h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-8">
                            <label class="form-label">Nombre y Apellido <span class="text-danger">*</span></label>
                            <input type="text" class="form-control minor-text" id="minorName" maxlength="150"
                                   placeholder="Nombre completo del menor" />
                            <div class="invalid-feedback" id="minorNameError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sexo <span class="text-danger">*</span></label>
                            <select class="form-select" id="minorSexId">
                                <option value="0">— Seleccionar —</option>
                                @foreach (var s in sexes)
                                {
                                    <option value="@s.SexId">@s.SexName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="minorSexError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fecha de Nacimiento <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="minorBirthdate" />
                            <div class="invalid-feedback" id="minorBirthdateError"></div>
                        </div>
                    </div>

                    <hr class="my-3" />
                    <h6 class="fw-semibold mb-3">
                        <i class="fas fa-user-shield text-primary me-1"></i> Datos del Representante
                    </h6>
                    <div class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label">Cédula <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="guardianIdNumber" maxlength="9"
                                       inputmode="numeric" placeholder="Ingrese la cédula"
                                       onblur="lookupGuardian()" />
                                <button class="btn btn-outline-secondary" type="button"
                                        onclick="lookupGuardian()" title="Buscar">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                            <div class="small mt-1" id="guardianLookupMsg"></div>
                            <div class="invalid-feedback" id="guardianCedulaError"></div>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">Nombre del Representante <span class="text-danger">*</span></label>
                            <input type="text" class="form-control guardian-text" id="guardianName" maxlength="150"
                                   placeholder="Nombre completo del representante" />
                            <div class="invalid-feedback" id="guardianNameError"></div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Dirección</label>
                            <input type="text" class="form-control guardian-text" id="guardianAddress"
                                   maxlength="300" placeholder="Dirección completa" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Parentesco <span class="text-danger">*</span></label>
                            <select class="form-select" id="guardianRelationshipIdNew">
                                <option value="0">— Seleccione —</option>
                                @foreach (var r in relationships)
                                {
                                    <option value="@r.RelationshipId">@r.RelationshipName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="guardianRelError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Sexo del Representante</label>
                            <select class="form-select" id="guardianSexId">
                                <option value="0">— Seleccionar —</option>
                                @foreach (var s in sexes)
                                {
                                    <option value="@s.SexId">@s.SexName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Fecha de Nacimiento</label>
                            <input type="date" class="form-control" id="guardianBirthdate" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Teléfono <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="guardianPhone" maxlength="15"
                                   inputmode="numeric" placeholder="Ej: 04141234567" />
                            <div class="invalid-feedback" id="guardianPhoneError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Correo electrónico <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="guardianEmail" maxlength="150"
                                   placeholder="nombre@correo.com" />
                            <div class="invalid-feedback" id="guardianEmailError"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Estado</label>
                            <select class="form-select" id="guardianStateId"
                                    onchange="loadGuardianMunicipalities(this.value, 0)">
                                <option value="0">— Seleccionar —</option>
                                @foreach (var st in states)
                                {
                                    <option value="@st.StateId">@st.StateName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Municipio</label>
                            <select class="form-select" id="guardianMunicipalityId">
                                <option value="0">— Seleccionar estado primero —</option>
                            </select>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSave" onclick="savePatient()">Guardar</button>
            </div>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════════════════════════════════════════════
     Save Confirm Modal
     ═══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="saveConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="saveConfirmMsg" class="mb-0">¿Desea guardar los cambios?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="confirmSave()">Confirmar</button>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     Delete Confirm Modal
     ═══════════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Eliminar Paciente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Eliminar a <strong id="deleteName"></strong>?</p>
                <p class="text-muted small mb-0">Se eliminarán también todos sus vínculos familiares.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="btnDelete" onclick="deletePatient()">Eliminar</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="toast" class="toast align-items-center text-white border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const patientModal     = new bootstrap.Modal(document.getElementById('patientModal'));
    const saveConfirmModal = new bootstrap.Modal(document.getElementById('saveConfirmModal'));
    const deleteModal      = new bootstrap.Modal(document.getElementById('deleteModal'));
    const toast            = new bootstrap.Toast(document.getElementById('toast'), { delay: 3500 });

    let pendingDeleteId    = 0;
    let filteredPatients  = [];
    let currentPage              = 1;
    let currentPatientType       = '';   // 'adult' | 'minor'
    let originalGuardianId       = 0;   // for edit minor: guardian before editing
    const PAGE_SIZE              = 10;

    const allPatients       = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const allSexes          = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sexes));
    const allStates         = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(states));
    const allMunicipalities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(municipalities));

    const patPerms = {
        canCreate: @(patPerms.CanCreate ? "true" : "false"),
        canEdit:   @(patPerms.CanEdit   ? "true" : "false"),
        canDelete: @(patPerms.CanDelete ? "true" : "false")
    };

    // ── Helpers ──────────────────────────────────────────────────────────────

    function showToast(message, success) {
        const el = document.getElementById('toast');
        el.classList.remove('bg-success', 'bg-danger');
        el.classList.add(success ? 'bg-success' : 'bg-danger');
        document.getElementById('toastMessage').textContent = message;
        toast.show();
    }

    function escapeHtml(text) {
        const d = document.createElement('div');
        d.textContent = text ?? '';
        return d.innerHTML;
    }

    function formatDateForInput(dateStr) {
        if (!dateStr) return '';
        const d = new Date(dateStr);
        if (isNaN(d.getTime())) return '';
        return d.toISOString().slice(0, 10);
    }

    function calcAge(dateStr) {
        if (!dateStr) return 0;
        const birth = new Date(dateStr);
        if (isNaN(birth.getTime())) return 0;
        const today = new Date();
        let age = today.getFullYear() - birth.getFullYear();
        if (today < new Date(today.getFullYear(), birth.getMonth(), birth.getDate())) age--;
        return Math.max(age, 0);
    }

    function setInvalid(fieldId, errId, msg) {
        const el = document.getElementById(fieldId);
        if (el) el.classList.add('is-invalid');
        const err = document.getElementById(errId);
        if (err) err.textContent = msg;
    }

    function clearInvalid(fieldId) {
        const el = document.getElementById(fieldId);
        if (el) el.classList.remove('is-invalid');
    }

    // ── Table ────────────────────────────────────────────────────────────────

    function renderTable() {
        const tbody = document.getElementById('patientBody');
        const start = (currentPage - 1) * PAGE_SIZE;
        const page  = filteredPatients.slice(start, start + PAGE_SIZE);

        if (filteredPatients.length === 0) {
            tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">No se encontraron pacientes.</td></tr>';
            renderPagination();
            return;
        }

        tbody.innerHTML = page.map(p => {
            const nameEscaped = (p.PatientName ?? '').replace(/'/g, "\\'");
            const cedula  = p.PatientIdNumber ? p.PatientIdNumber : '—';
            const age     = p.Age > 0 ? p.Age + ' años' : (p.Age === 0 ? '< 1 año' : '—');
            const phone   = p.PatientMainPhone ? String(p.PatientMainPhone) : '—';
            const state   = escapeHtml(p.StateName ?? '—');
            const family  = p.FamilyCount > 0
                ? `<span class="badge bg-info text-dark"><i class="fas fa-users me-1"></i>${p.FamilyCount}</span>`
                : '<span class="text-muted small">—</span>';
            const btnEdit   = patPerms.canEdit
                ? `<button class="btn btn-sm btn-outline-primary me-1" onclick="editPatient(${p.PatientId})" title="Editar"><i class="fas fa-edit"></i></button>`
                : '';
            const btnDelete = patPerms.canDelete
                ? `<button class="btn btn-sm btn-outline-danger" onclick="confirmDelete(${p.PatientId},'${nameEscaped}')" title="Eliminar"><i class="fas fa-trash"></i></button>`
                : '';
            return `<tr data-id="${p.PatientId}">
                <td>${p.PatientId}</td>
                <td>${escapeHtml(p.PatientName ?? '')}</td>
                <td>${cedula}</td>
                <td>${age}</td>
                <td>${phone}</td>
                <td>${state}</td>
                <td>${family}</td>
                <td class="text-end">
                    ${btnEdit}
                    <a class="btn btn-sm btn-outline-info me-1" href="/Patient/History/${p.PatientId}" title="Historia Médica"><i class="fas fa-file-medical"></i></a>
                    ${btnDelete}
                </td>
            </tr>`;
        }).join('');

        renderPagination();
    }

    function renderPagination() {
        const total      = filteredPatients.length;
        const totalPages = Math.ceil(total / PAGE_SIZE);
        const pag        = document.getElementById('pagination');
        const info       = document.getElementById('paginationInfo');

        if (total === 0) { info.textContent = ''; pag.innerHTML = ''; return; }

        const start = (currentPage - 1) * PAGE_SIZE + 1;
        const end   = Math.min(currentPage * PAGE_SIZE, total);
        info.textContent = `Mostrando ${start}–${end} de ${total}`;

        if (totalPages <= 1) { pag.innerHTML = ''; return; }

        const pages  = new Set([1, totalPages]);
        for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) pages.add(i);
        const sorted = [...pages].sort((a, b) => a - b);

        let html = `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="goToPage(${currentPage - 1});return false;">&lsaquo;</a></li>`;
        let prev = 0;
        for (const p of sorted) {
            if (p - prev > 1) html += `<li class="page-item disabled"><span class="page-link">&hellip;</span></li>`;
            html += `<li class="page-item ${p === currentPage ? 'active' : ''}">
                <a class="page-link" href="#" onclick="goToPage(${p});return false;">${p}</a></li>`;
            prev = p;
        }
        html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="goToPage(${currentPage + 1});return false;">&rsaquo;</a></li>`;
        pag.innerHTML = html;
    }

    function goToPage(page) {
        const totalPages = Math.max(1, Math.ceil(filteredPatients.length / PAGE_SIZE));
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderTable();
    }

    function applyFilters() {
        const q = (document.getElementById('searchInput').value ?? '').trim().toLowerCase();
        filteredPatients = q
            ? allPatients.filter(p => {
                const name  = (p.PatientName ?? '').toLowerCase();
                const id    = p.PatientIdNumber ? String(p.PatientIdNumber) : '';
                const phone = p.PatientMainPhone ? String(p.PatientMainPhone) : '';
                const state = (p.StateName ?? '').toLowerCase();
                return name.includes(q) || id.includes(q) || phone.includes(q) || state.includes(q);
            })
            : [...allPatients];
        currentPage = 1;
        renderTable();
    }

    function clearSearch() {
        document.getElementById('searchInput').value = '';
        applyFilters();
    }

    // ── Municipality loaders ─────────────────────────────────────────────────

    function loadMunicipalities(stateId, preselectId = 0) {
        const sel = document.getElementById('patientMunicipalityId');
        const sid = parseInt(stateId) || 0;
        if (sid === 0) {
            sel.innerHTML = '<option value="0">— Seleccionar estado primero —</option>';
            return;
        }
        const filtered = allMunicipalities.filter(m => m.StateId === sid);
        sel.innerHTML = '<option value="0">— Seleccionar —</option>';
        filtered.forEach(m => {
            const opt = document.createElement('option');
            opt.value       = m.MunicipalityId;
            opt.textContent = m.MunicipalityName;
            if (m.MunicipalityId === preselectId) opt.selected = true;
            sel.appendChild(opt);
        });
    }

    function loadGuardianMunicipalities(stateId, preselectId = 0) {
        const sel = document.getElementById('guardianMunicipalityId');
        const sid = parseInt(stateId) || 0;
        if (sid === 0) {
            sel.innerHTML = '<option value="0">— Seleccionar estado primero —</option>';
            return;
        }
        const filtered = allMunicipalities.filter(m => m.StateId === sid);
        sel.innerHTML = '<option value="0">— Seleccionar —</option>';
        filtered.forEach(m => {
            const opt = document.createElement('option');
            opt.value       = m.MunicipalityId;
            opt.textContent = m.MunicipalityName;
            if (m.MunicipalityId === preselectId) opt.selected = true;
            sel.appendChild(opt);
        });
    }

    // ── Patient modal — open / type change ───────────────────────────────────

    function openModal() {
        document.getElementById('patientId').value      = '0';
        document.getElementById('guardianPatientId').value = '0';
        originalGuardianId  = 0;
        currentPatientType  = '';

        document.getElementById('typeAdult').checked   = false;
        document.getElementById('typeMinor').checked   = false;
        document.getElementById('typeAdult').disabled  = false;
        document.getElementById('typeMinor').disabled  = false;
        document.getElementById('adultSection').classList.add('d-none');
        document.getElementById('minorSection').classList.add('d-none');

        resetAdultFields();
        resetMinorFields();

        document.getElementById('modalTitle').textContent = 'Nuevo Paciente';
        patientModal.show();
    }

    function onPatientTypeChange(type) {
        currentPatientType = type;
        if (type === 'adult') {
            document.getElementById('adultSection').classList.remove('d-none');
            document.getElementById('minorSection').classList.add('d-none');
            setTimeout(() => document.getElementById('patientName').focus(), 100);
        } else {
            document.getElementById('adultSection').classList.add('d-none');
            document.getElementById('minorSection').classList.remove('d-none');
            setTimeout(() => document.getElementById('minorName').focus(), 100);
        }
    }

    function resetAdultFields() {
        ['patientName','patientSexId','patientIdNumber','patientBirthdate',
         'patientMainPhone','patientEmail','patientAddress'].forEach(id => {
            const el = document.getElementById(id);
            if (el) { el.value = el.tagName === 'SELECT' ? '0' : ''; el.classList.remove('is-invalid'); }
        });
        document.getElementById('patientMunicipalityId').innerHTML =
            '<option value="0">— Seleccionar estado primero —</option>';
        document.getElementById('patientStateId').value = '0';
    }

    function resetMinorFields() {
        ['minorName','minorSexId','minorBirthdate',
         'guardianIdNumber','guardianName','guardianAddress','guardianSexId',
         'guardianBirthdate','guardianPhone','guardianEmail','guardianStateId','guardianRelationshipIdNew'].forEach(id => {
            const el = document.getElementById(id);
            if (el) { el.value = el.tagName === 'SELECT' ? '0' : ''; el.classList.remove('is-invalid'); }
        });
        document.getElementById('guardianMunicipalityId').innerHTML =
            '<option value="0">— Seleccionar estado primero —</option>';
        const msg = document.getElementById('guardianLookupMsg');
        msg.textContent = '';
        msg.className = 'small mt-1';
    }

    // ── Guardian lookup (patient modal — minor section) ──────────────────────

    function lookupGuardian() {
        const cedulaStr = document.getElementById('guardianIdNumber').value.trim();
        const msg       = document.getElementById('guardianLookupMsg');

        if (!cedulaStr || !/^\d+$/.test(cedulaStr)) {
            msg.textContent = '';
            return;
        }

        msg.textContent = 'Buscando...';
        msg.className   = 'text-muted small mt-1';

        fetch(`/Patient/GetByCedula?cedula=${cedulaStr}`)
            .then(r => r.ok ? r.json() : Promise.reject())
            .then(data => {
                const gid = data.patientId ?? 0;
                document.getElementById('guardianPatientId').value = gid;
                document.getElementById('guardianName').value      = data.patientName ?? '';
                document.getElementById('guardianSexId').value     = data.sexId ?? 0;
                document.getElementById('guardianBirthdate').value = formatDateForInput(data.patientBirthdate);
                document.getElementById('guardianPhone').value     = data.patientMainPhone ? String(data.patientMainPhone) : '';
                document.getElementById('guardianEmail').value     = data.patientEmail ?? '';
                document.getElementById('guardianAddress').value   = data.patientAddress ?? '';
                const stateId = data.stateId ?? 0;
                document.getElementById('guardianStateId').value   = stateId;
                loadGuardianMunicipalities(stateId, data.municipalityId ?? 0);
                msg.textContent = 'Representante encontrado — datos pre-llenados.';
                msg.className   = 'text-success small mt-1';
            })
            .catch(() => {
                document.getElementById('guardianPatientId').value = '0';
                clearGuardianDataFields();
                msg.textContent = 'Cédula no encontrada. Complete los datos manualmente.';
                msg.className   = 'text-warning small mt-1';
            });
    }

    function clearGuardianDataFields() {
        ['guardianName','guardianSexId','guardianBirthdate',
         'guardianPhone','guardianEmail','guardianAddress','guardianStateId'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.value = el.tagName === 'SELECT' ? '0' : '';
        });
        document.getElementById('guardianMunicipalityId').innerHTML =
            '<option value="0">— Seleccionar estado primero —</option>';
    }

    // ── Edit patient ─────────────────────────────────────────────────────────

    function editPatient(id) {
        const p = allPatients.find(x => x.PatientId === id);
        if (!p) return;

        document.getElementById('patientId').value         = p.PatientId;
        document.getElementById('guardianPatientId').value = '0';
        originalGuardianId  = 0;
        document.getElementById('typeAdult').disabled  = true;
        document.getElementById('typeMinor').disabled  = true;
        document.getElementById('modalTitle').textContent = 'Editar Paciente';

        if (p.HasGuardian) {
            // ── Minor ──
            currentPatientType = 'minor';
            document.getElementById('typeMinor').checked = true;
            document.getElementById('adultSection').classList.add('d-none');
            document.getElementById('minorSection').classList.remove('d-none');
            resetMinorFields();

            document.getElementById('minorName').value      = p.PatientName ?? '';
            document.getElementById('minorSexId').value     = p.SexId ?? 0;
            document.getElementById('minorBirthdate').value = formatDateForInput(p.PatientBirthdate);

            // Load guardian data
            const msg = document.getElementById('guardianLookupMsg');
            msg.textContent = 'Cargando...';
            msg.className   = 'text-muted small mt-1';

            fetch(`/Patient/GetFamily?patientId=${id}`)
                .then(r => r.json())
                .then(family => {
                    const g = family.find(m => (m.role ?? m.Role) === 'guardian');
                    if (!g) { msg.textContent = ''; return; }

                    const gid = g.patientId ?? g.PatientId ?? 0;
                    document.getElementById('guardianPatientId').value = gid;
                    originalGuardianId = gid;

                    const idNum = g.patientIdNumber ?? g.PatientIdNumber;
                    document.getElementById('guardianIdNumber').value    = idNum ? String(idNum) : '';
                    document.getElementById('guardianName').value        = g.patientName      ?? g.PatientName      ?? '';
                    document.getElementById('guardianSexId').value       = g.sexId            ?? g.SexId            ?? 0;
                    document.getElementById('guardianBirthdate').value   = formatDateForInput(g.patientBirthdate  ?? g.PatientBirthdate);
                    document.getElementById('guardianPhone').value       = (g.patientMainPhone ?? g.PatientMainPhone)
                        ? String(g.patientMainPhone ?? g.PatientMainPhone) : '';
                    document.getElementById('guardianEmail').value       = g.patientEmail ?? g.PatientEmail ?? '';
                    document.getElementById('guardianAddress').value     = g.patientAddress   ?? g.PatientAddress   ?? '';
                    document.getElementById('guardianRelationshipIdNew').value = g.relationshipId ?? g.RelationshipId ?? 0;
                    const stateId = g.stateId ?? g.StateId ?? 0;
                    document.getElementById('guardianStateId').value     = stateId;
                    loadGuardianMunicipalities(stateId, g.municipalityId ?? g.MunicipalityId ?? 0);
                    msg.textContent = '';
                })
                .catch(() => { document.getElementById('guardianLookupMsg').textContent = ''; });

        } else {
            // ── Adult ──
            currentPatientType = 'adult';
            document.getElementById('typeAdult').checked = true;
            document.getElementById('adultSection').classList.remove('d-none');
            document.getElementById('minorSection').classList.add('d-none');
            resetAdultFields();

            document.getElementById('patientName').value      = p.PatientName ?? '';
            document.getElementById('patientSexId').value     = p.SexId ?? 0;
            document.getElementById('patientIdNumber').value  = p.PatientIdNumber ?? '';
            document.getElementById('patientBirthdate').value = formatDateForInput(p.PatientBirthdate);
            document.getElementById('patientMainPhone').value = p.PatientMainPhone ? String(p.PatientMainPhone) : '';
            document.getElementById('patientEmail').value     = p.PatientEmail ?? '';
            document.getElementById('patientStateId').value   = p.StateId ?? 0;
            loadMunicipalities(p.StateId ?? 0, p.MunicipalityId ?? 0);
            document.getElementById('patientAddress').value   = p.PatientAddress ?? '';
        }

        patientModal.show();
    }

    // ── Save ─────────────────────────────────────────────────────────────────

    function savePatient() {
        if (!currentPatientType) {
            document.getElementById('typeError').textContent = 'Seleccione el tipo de paciente.';
            document.getElementById('typeError').style.display = 'block';
            return;
        }
        document.getElementById('typeError').style.display = 'none';
        const isNew = parseInt(document.getElementById('patientId').value) === 0;
        document.getElementById('saveConfirmMsg').textContent = isNew
            ? '¿Desea registrar este paciente?'
            : '¿Desea guardar los cambios?';
        saveConfirmModal.show();
    }

    function confirmSave() {
        saveConfirmModal.hide();
        if (currentPatientType === 'adult') saveAdult();
        else saveMinor();
    }

    function saveAdult() {
        let valid = true;

        const name = document.getElementById('patientName').value.trim();
        if (!name) { setInvalid('patientName', 'nameError', 'El nombre es requerido.'); valid = false; }
        else clearInvalid('patientName');

        const sexId = parseInt(document.getElementById('patientSexId').value) || 0;
        if (!sexId) { setInvalid('patientSexId', 'sexError', 'Seleccione el sexo.'); valid = false; }
        else clearInvalid('patientSexId');

        const cedulaStr = document.getElementById('patientIdNumber').value.trim();
        if (!cedulaStr) { setInvalid('patientIdNumber', 'cedulaError', 'La cédula es requerida.'); valid = false; }
        else clearInvalid('patientIdNumber');

        const birthdate = document.getElementById('patientBirthdate').value;
        if (!birthdate) { setInvalid('patientBirthdate', 'birthdateError', 'La fecha de nacimiento es requerida.'); valid = false; }
        else clearInvalid('patientBirthdate');

        const phoneRaw = document.getElementById('patientMainPhone').value.trim();
        if (!phoneRaw) { setInvalid('patientMainPhone', 'phoneError', 'El teléfono es requerido.'); valid = false; }
        else clearInvalid('patientMainPhone');

        const emailRe = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        const emailVal = document.getElementById('patientEmail').value.trim();
        if (!emailVal)          { setInvalid('patientEmail', 'emailError', 'El correo electrónico es requerido.');  valid = false; }
        else if (!emailRe.test(emailVal)) { setInvalid('patientEmail', 'emailError', 'El correo electrónico no es válido.'); valid = false; }
        else clearInvalid('patientEmail');

        if (!valid) return;

        const id       = parseInt(document.getElementById('patientId').value);
        const stateId  = parseInt(document.getElementById('patientStateId').value) || 0;
        const muniId   = parseInt(document.getElementById('patientMunicipalityId').value) || 0;
        const stateEntry = allStates.find(s => s.StateId === stateId);
        const muniSel    = document.getElementById('patientMunicipalityId');
        const muniName   = muniSel.options[muniSel.selectedIndex]?.text ?? null;
        const sexEntry   = allSexes.find(s => s.SexId === sexId);

        const payload = {
            patientId:        id,
            patientName:      name,
            patientEmail:     emailVal,
            sexId:            sexId,
            patientIdNumber:  parseInt(cedulaStr) || null,
            patientBirthdate: birthdate,
            patientMainPhone: parseInt(phoneRaw.replace(/\D/g, '')) || 0,
            municipalityId:   muniId,
            patientAddress:   document.getElementById('patientAddress').value.trim() || null,
            isGuardianOnly:   false
        };

        document.getElementById('btnSave').disabled = true;

        fetch('/Patient/Save', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(payload)
        })
        .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e)))
        .then(data => {
            patientModal.hide();
            const newId  = id === 0 ? data.patientId : id;
            const newDoc = {
                PatientId:        newId,
                PatientName:      name,
                PatientEmail:     emailVal,
                SexId:            sexId,
                SexName:          sexEntry?.SexName ?? null,
                PatientIdNumber:  payload.patientIdNumber,
                PatientBirthdate: birthdate,
                Age:              calcAge(birthdate),
                PatientMainPhone: payload.patientMainPhone,
                MunicipalityId:   muniId,
                MunicipalityName: muniId > 0 ? (muniName !== '— Seleccionar —' ? muniName : null) : null,
                StateId:          stateId,
                StateName:        stateEntry?.StateName ?? null,
                PatientAddress:   payload.patientAddress,
                FamilyCount:      id === 0 ? 0 : (allPatients.find(x => x.PatientId === id)?.FamilyCount ?? 0),
                HasGuardian:      false,
            };
            if (id === 0) allPatients.push(newDoc);
            else { const idx = allPatients.findIndex(x => x.PatientId === id); if (idx >= 0) allPatients[idx] = newDoc; }
            applyFilters();
            showToast(id === 0 ? 'Paciente registrado correctamente.' : 'Paciente actualizado correctamente.', true);
        })
        .catch(err => showToast(err?.message ?? 'Error al guardar el paciente.', false))
        .finally(() => { document.getElementById('btnSave').disabled = false; });
    }

    function saveMinor() {
        let valid = true;

        const minorName = document.getElementById('minorName').value.trim();
        if (!minorName) { setInvalid('minorName', 'minorNameError', 'El nombre del menor es requerido.'); valid = false; }
        else clearInvalid('minorName');

        const minorSexId = parseInt(document.getElementById('minorSexId').value) || 0;
        if (!minorSexId) { setInvalid('minorSexId', 'minorSexError', 'Seleccione el sexo del menor.'); valid = false; }
        else clearInvalid('minorSexId');

        const minorBirthdate = document.getElementById('minorBirthdate').value;
        if (!minorBirthdate) { setInvalid('minorBirthdate', 'minorBirthdateError', 'La fecha de nacimiento es requerida.'); valid = false; }
        else clearInvalid('minorBirthdate');

        const guardianCedula = document.getElementById('guardianIdNumber').value.trim();
        if (!guardianCedula) { setInvalid('guardianIdNumber', 'guardianCedulaError', 'La cédula del representante es requerida.'); valid = false; }
        else clearInvalid('guardianIdNumber');

        const guardianName = document.getElementById('guardianName').value.trim();
        if (!guardianName) { setInvalid('guardianName', 'guardianNameError', 'El nombre del representante es requerido.'); valid = false; }
        else clearInvalid('guardianName');

        const relId = parseInt(document.getElementById('guardianRelationshipIdNew').value) || 0;
        if (!relId) { setInvalid('guardianRelationshipIdNew', 'guardianRelError', 'Seleccione el parentesco.'); valid = false; }
        else clearInvalid('guardianRelationshipIdNew');

        const guardianPhoneRaw = document.getElementById('guardianPhone').value.trim();
        if (!guardianPhoneRaw) { setInvalid('guardianPhone', 'guardianPhoneError', 'El teléfono del representante es requerido.'); valid = false; }
        else clearInvalid('guardianPhone');

        const emailRe = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
        const guardianEmailVal = document.getElementById('guardianEmail').value.trim();
        if (!guardianEmailVal)          { setInvalid('guardianEmail', 'guardianEmailError', 'El correo del representante es requerido.');  valid = false; }
        else if (!emailRe.test(guardianEmailVal)) { setInvalid('guardianEmail', 'guardianEmailError', 'El correo electrónico no es válido.'); valid = false; }
        else clearInvalid('guardianEmail');

        if (!valid) return;

        const minorPatientId = parseInt(document.getElementById('patientId').value);
        let   guardianId     = parseInt(document.getElementById('guardianPatientId').value) || 0;

        const guardianSexId   = parseInt(document.getElementById('guardianSexId').value)   || 0;
        const guardianStateId = parseInt(document.getElementById('guardianStateId').value)  || 0;
        const guardianMuniId  = parseInt(document.getElementById('guardianMunicipalityId').value) || 0;
        const guardianMuniSel = document.getElementById('guardianMunicipalityId');
        const guardianMuniName= guardianMuniSel.options[guardianMuniSel.selectedIndex]?.text ?? null;
        const guardianStateEntry = allStates.find(s => s.StateId === guardianStateId);
        const minorSexEntry      = allSexes.find(s => s.SexId === minorSexId);
        const guardianPhone      = parseInt(guardianPhoneRaw.replace(/\D/g, '')) || 0;

        const guardianPayload = {
            patientId:        guardianId,
            patientName:      guardianName,
            patientEmail:     guardianEmailVal,
            sexId:            guardianSexId,
            patientIdNumber:  parseInt(guardianCedula) || null,
            patientBirthdate: document.getElementById('guardianBirthdate').value || null,
            patientMainPhone: guardianPhone,
            municipalityId:   guardianMuniId,
            patientAddress:   document.getElementById('guardianAddress').value.trim() || null,
            isGuardianOnly:   true
        };

        const minorPayload = {
            patientId:        minorPatientId,
            patientName:      minorName,
            // Patient.PatientEmail es NOT NULL → reutilizamos el del representante.
            patientEmail:     guardianEmailVal,
            sexId:            minorSexId,
            patientIdNumber:  null,
            patientBirthdate: minorBirthdate,
            patientMainPhone: 0,
            municipalityId:   guardianMuniId,
            patientAddress:   guardianPayload.patientAddress,
            isGuardianOnly:   false
        };

        document.getElementById('btnSave').disabled = true;

        // Step 1: Save guardian
        fetch('/Patient/Save', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(guardianPayload)
        })
        .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e)))
        .then(gData => {
            const newGuardianId = gData.patientId ?? gData.PatientId;
            // Step 2: Save minor
            return fetch('/Patient/Save', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(minorPayload)
            })
            .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e)))
            .then(mData => ({ minorId: mData.patientId ?? mData.PatientId, newGuardianId }));
        })
        .then(({ minorId, newGuardianId }) => {
            // Step 3: Remove old guardian link if guardian changed
            const oldId = originalGuardianId;
            const removePromise = (oldId > 0 && oldId !== newGuardianId)
                ? fetch('/Patient/RemoveGuardian', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ patientId: minorId, guardianPatientId: oldId })
                  })
                : Promise.resolve();
            return removePromise.then(() => ({ minorId, newGuardianId }));
        })
        .then(({ minorId, newGuardianId }) => {
            // Step 4: Create/update guardian link
            return fetch('/Patient/SaveGuardian', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ patientId: minorId, guardianPatientId: newGuardianId, relationshipId: relId })
            })
            .then(r => { if (!r.ok) return Promise.reject({ message: 'Error al vincular el representante.' }); })
            .then(() => minorId);
        })
        .then(minorId => {
            patientModal.hide();
            const newDoc = {
                PatientId:        minorId,
                PatientName:      minorName,
                PatientEmail:     guardianEmailVal,
                SexId:            minorSexId,
                SexName:          minorSexEntry?.SexName ?? null,
                PatientIdNumber:  null,
                PatientBirthdate: minorBirthdate,
                Age:              calcAge(minorBirthdate),
                PatientMainPhone: guardianPhone,
                MunicipalityId:   guardianMuniId,
                MunicipalityName: guardianMuniId > 0 ? (guardianMuniName !== '— Seleccionar —' ? guardianMuniName : null) : null,
                StateId:          guardianStateId,
                StateName:        guardianStateEntry?.StateName ?? null,
                PatientAddress:   guardianPayload.patientAddress,
                FamilyCount:      minorPatientId === 0 ? 1 : (allPatients.find(x => x.PatientId === minorPatientId)?.FamilyCount ?? 1),
                HasGuardian:      true,
            };
            if (minorPatientId === 0) allPatients.push(newDoc);
            else { const idx = allPatients.findIndex(x => x.PatientId === minorPatientId); if (idx >= 0) allPatients[idx] = newDoc; }
            applyFilters();
            showToast(minorPatientId === 0 ? 'Menor registrado correctamente.' : 'Menor actualizado correctamente.', true);
        })
        .catch(err => showToast(err?.message ?? 'Error al guardar el paciente.', false))
        .finally(() => { document.getElementById('btnSave').disabled = false; });
    }


    // ── Delete ───────────────────────────────────────────────────────────────

    function confirmDelete(id, name) {
        pendingDeleteId = id;
        document.getElementById('deleteName').textContent = name;
        deleteModal.show();
    }

    function deletePatient() {
        document.getElementById('btnDelete').disabled = true;
        fetch('/Patient/Delete', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(pendingDeleteId)
        })
        .then(r => {
            if (!r.ok) return Promise.reject();
            deleteModal.hide();
            const idx = allPatients.findIndex(x => x.PatientId === pendingDeleteId);
            if (idx >= 0) allPatients.splice(idx, 1);
            applyFilters();
            showToast('Paciente eliminado correctamente.', true);
        })
        .catch(() => showToast('Error al eliminar el paciente.', false))
        .finally(() => { document.getElementById('btnDelete').disabled = false; });
    }

    // ── Input behavior ───────────────────────────────────────────────────────

    (function () {
        const accentMap = { 'á':'A','é':'E','í':'I','ó':'O','ú':'U','ü':'U','ñ':'Ñ','Á':'A','É':'E','Í':'I','Ó':'O','Ú':'U','Ü':'U' };
        function up(str) { return str.replace(/[áéíóúüñÁÉÍÓÚÜ]/g, c => accentMap[c] || c).toUpperCase(); }
        document.querySelectorAll('.pat-text, .minor-text, .guardian-text').forEach(el => {
            el.addEventListener('input', function () {
                const pos = this.selectionStart;
                this.value = up(this.value);
                this.setSelectionRange(pos, pos);
            });
            el.addEventListener('paste', function (e) {
                e.preventDefault();
                const text = (e.clipboardData || window.clipboardData).getData('text');
                const pos = this.selectionStart, end = this.selectionEnd;
                this.value = up(this.value.slice(0, pos) + text + this.value.slice(end));
                this.setSelectionRange(pos + text.length, pos + text.length);
            });
        });
    })();

    (function () {
        ['patientIdNumber', 'guardianIdNumber'].forEach(elId => {
            const el = document.getElementById(elId);
            if (!el) return;
            el.addEventListener('keydown', function (e) {
                if (['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Home','End'].includes(e.key)) return;
                if (e.ctrlKey || e.metaKey) return;
                if (!/^\d$/.test(e.key)) e.preventDefault();
            });
            el.addEventListener('input', function () {
                this.value = this.value.replace(/\D/g, '').slice(0, 9);
            });
        });
    })();

    (function () {
        ['patientMainPhone', 'guardianPhone'].forEach(elId => {
            const el = document.getElementById(elId);
            if (!el) return;
            el.addEventListener('keydown', function (e) {
                if (['Backspace','Delete','ArrowLeft','ArrowRight','Tab','Home','End'].includes(e.key)) return;
                if (e.ctrlKey || e.metaKey) return;
                if (!/^\d$/.test(e.key)) e.preventDefault();
            });
            el.addEventListener('input', function () { this.value = this.value.replace(/\D/g, ''); });
        });
    })();

    applyFilters();
</script>
}
