@model Medycally.Models.AppointmentDetailModel
@{
    Layout = null;
    var att = ViewBag.Attention as Medycally.Models.MedicalAttentionModel;
    var isMinor = Model.PatientTypeId == 2;

    var culturaEs = System.Globalization.CultureInfo.GetCultureInfo("es-ES");
    var fechaAtencionLarga = Model.AppointmentDate.ToString("d 'de' MMMM 'del' yyyy", culturaEs);
    var fechaAtencionCorta = Model.AppointmentDate.ToString("dd/MM/yyyy", culturaEs);
    var fechaEmision       = DateTime.Now.ToString("dd/MM/yyyy");

    // Sexo en sustantivo (mujer / hombre) para la narrativa de la carta.
    string SexoSustantivo(string? sexName)
    {
        if (string.IsNullOrWhiteSpace(sexName)) return "paciente";
        var s = sexName.Trim().ToLowerInvariant();
        if (s.StartsWith("f") || s.StartsWith("muj")) return "mujer";
        if (s.StartsWith("masc") || s == "m" || s.StartsWith("homb")) return "hombre";
        return s;
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Informe Médico — @Model.PatientName</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Times New Roman', Times, serif;
            font-size: 13px;
            color: #000;
            padding: 60px 70px;
            line-height: 1.45;
            background: #fff;
        }
        .center { text-align: center; }
        .clinic-name {
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1px;
            margin-bottom: 26px;
            text-transform: uppercase;
        }
        .report-title {
            font-size: 15px;
            font-weight: 700;
            text-decoration: underline;
            margin-bottom: 22px;
            text-transform: uppercase;
        }
        .patient-grid {
            margin: 0 0 6px 0;
        }
        .patient-grid .row {
            display: flex;
            margin-bottom: 2px;
        }
        .patient-grid .lbl {
            width: 220px;
            font-weight: 700;
            text-transform: uppercase;
        }
        .patient-grid .sep { width: 14px; font-weight: 700; }
        .patient-grid .val { flex: 1; }
        .divider {
            border-top: 1px solid #000;
            margin: 14px 0 18px 0;
        }
        p.narrative {
            text-align: justify;
            margin-bottom: 12px;
        }
        .block-title {
            font-weight: 700;
            text-transform: uppercase;
            margin-top: 14px;
            margin-bottom: 6px;
        }
        .diag-list {
            padding-left: 0;
            list-style: none;
        }
        .diag-list li { margin-bottom: 2px; }
        .signature {
            margin-top: 70px;
            text-align: center;
        }
        .signature .name { font-weight: 700; text-transform: uppercase; }
        .signature .spec { font-style: italic; }
        .no-print { margin-bottom: 18px; text-align: center; }
        .no-print button {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 13px; padding: 7px 18px; cursor: pointer;
            border: none; border-radius: 4px; margin: 0 4px;
        }
        .btn-print { background: #0d6efd; color: #fff; }
        .btn-close { background: #6c757d; color: #fff; }
        @@media print {
            .no-print { display: none !important; }
            body { padding: 30px 50px; }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button class="btn-print" onclick="window.print()">🖨️ Imprimir / Guardar PDF</button>
        <button class="btn-close" onclick="window.close()">Cerrar</button>
    </div>

    <div class="center clinic-name">
        @(string.IsNullOrWhiteSpace(Model.ClinicName) ? "Nombre del Centro Médico" : Model.ClinicName)
    </div>

    <div class="center report-title">Informe Médico</div>

    <div class="patient-grid">
        <div class="row">
            <div class="lbl">Paciente</div><div class="sep">:</div>
            <div class="val">@(Model.PatientName ?? "—")</div>
        </div>
        <div class="row">
            <div class="lbl">Edad</div><div class="sep">:</div>
            <div class="val">@Model.PatientAge AÑOS</div>
        </div>
        <div class="row">
            <div class="lbl">Cédula</div><div class="sep">:</div>
            <div class="val">@(Model.PatientIdNumber > 0 ? "V-" + Model.PatientIdNumber.ToString("N0", culturaEs).Replace(".", "") : "Sin cédula")</div>
        </div>
        <div class="row">
            <div class="lbl">Fecha de Atención</div><div class="sep">:</div>
            <div class="val">@(string.IsNullOrWhiteSpace(Model.PatientStateName) ? "" : Model.PatientStateName + ", ")@fechaAtencionLarga</div>
        </div>
        @if (isMinor && !string.IsNullOrWhiteSpace(Model.ChildGuardianName))
        {
            <div class="row">
                <div class="lbl">Representante</div><div class="sep">:</div>
                <div class="val">@Model.ChildGuardianName@(!string.IsNullOrWhiteSpace(Model.RelationshipName) ? " (" + Model.RelationshipName + ")" : "")</div>
            </div>
        }
    </div>

    <div class="divider"></div>

    @{
        var sexoTxt       = SexoSustantivo(Model.PatientSexName);
        var especialidad  = string.IsNullOrWhiteSpace(Model.SpecialtyName) ? "consulta" : Model.SpecialtyName;
        var chief         = (att?.ChiefComplaint ?? "").Trim();
        var current       = (att?.CurrentIlness  ?? "").Trim();
        var diagnosis     = (att?.Diagnosis      ?? "").Trim();
        var treatment     = (att?.Treatment      ?? "").Trim();
        var labs          = (att?.LaboratoryTests ?? "").Trim();
        var testReq       = (att?.TestRequisition ?? "").Trim();
        var notes         = (att?.Notes          ?? "").Trim();

        string EnsureDot(string s) =>
            string.IsNullOrEmpty(s) ? s : (s.EndsWith(".") || s.EndsWith(",") ? s : s + ".");

        var introBuilder = new System.Text.StringBuilder();
        introBuilder.Append($"Paciente {sexoTxt} de {Model.PatientAge} años, quien acude a consulta de {especialidad} el día {fechaAtencionCorta}");
        if (string.IsNullOrEmpty(chief) && string.IsNullOrEmpty(current) && string.IsNullOrEmpty(diagnosis))
            introBuilder.Append('.');
        else
            introBuilder.Append(',');
        if (!string.IsNullOrEmpty(chief))     introBuilder.Append(' ').Append(EnsureDot(chief));
        if (!string.IsNullOrEmpty(current))   introBuilder.Append(' ').Append(EnsureDot(current));
        if (!string.IsNullOrEmpty(diagnosis)) introBuilder.Append(' ').Append(EnsureDot(diagnosis));
        var intro = introBuilder.ToString();
    }

    <p class="narrative">@intro</p>

    @if (!string.IsNullOrEmpty(treatment))
    {
        <p class="narrative" style="white-space: pre-wrap;">@treatment</p>
    }

    @if (!string.IsNullOrEmpty(labs))
    {
        <p class="narrative" style="white-space: pre-wrap;">@labs</p>
    }

    @if (!string.IsNullOrEmpty(testReq))
    {
        <p class="narrative" style="white-space: pre-wrap;">@testReq</p>
    }

    @if (!string.IsNullOrEmpty(notes))
    {
        <p class="narrative" style="white-space: pre-wrap;">@notes</p>
    }

    <div class="signature">
        ____________________________________<br />
        <span class="name">@(Model.DoctorName ?? "Nombre del Doctor")</span><br />
        <span class="spec">@(Model.SpecialtyName ?? "Especialidad")</span>
    </div>

    <script>
        window.onload = function () { window.focus(); window.print(); };
    </script>
</body>
</html>
