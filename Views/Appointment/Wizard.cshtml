            <div class="col-5 k">Médico</div><div class="col-7 v">${s.doctor}</div>
            <div class="col-5 k">Fecha</div><div class="col-7 v">${s.day}, ${s.date}</div>
            <div class="col-5 k">Horario</div><div class="col-7 v">${s.time} (${s.shift})</div>
            <div class="col-5 k">Responsable</div><div class="col-7 v">${document.getElementById('selPayer').value}</div>
            <div class="col-5 k">Motivo</div><div class="col-7 v">${document.getElementById('reasonSearch').value || '—'}</div>
        </div>`;
