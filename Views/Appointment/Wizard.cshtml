    const idNumber = raw.replace(/\D/g, '');
    if (!idNumber) { markInvalid('existingIdNumber'); return; }

    const btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Buscando...';

    const errEl = document.getElementById('idNumberError');

    try {
        const resp = await fetch(`/Appointment/GetPatientByIdNumber?idNumber=${idNumber}&patientType=${state.patientType}`);
        const data = await resp.json();

        if (!data.found) {
            document.getElementById('existingIdNumber').classList.add('is-invalid');
            if (errEl) errEl.textContent = 'No se encontró ningún paciente con esa cédula.';
            return;
        }

        document.getElementById('existingIdNumber').classList.remove('is-invalid');
        if (errEl) errEl.textContent = '';

        state.patientId              = data.patientId;
        state.patientName            = data.patientName;
        state.idNumber                 = data.patientIdNumber;
        state.age                    = data.age;
        state.sexId                  = data.sexId;
        state.childGuardianIdNumber  = data.childGuardianIdNumber;
        state.childGuardianName      = data.childGuardianName;
        state.relationshipId         = data.relationshipId;
        state.step6BackTarget           = 'step-4b';

        document.getElementById('patientBadgeName').textContent = data.patientName;
        document.getElementById('pbIdNumber').textContent         = data.patientIdNumber;
        document.getElementById('pbAge').textContent            = data.age;
        document.getElementById('pbSex').textContent            = data.sexText;

        if (state.patientType === 'minor') {
            // Pre-llenamos todos los campos del representante en step-5b
            document.getElementById('guardianIdNumber').value  = idNumber;
            document.getElementById('guardianName').value      = (data.childGuardianName && data.childGuardianName !== '—') ? data.childGuardianName : '';
            document.getElementById('guardianAddress').value   = data.childGuardianAddress  || '';
            document.getElementById('guardianPhone').value     = data.childGuardianPhone    || '';
            document.getElementById('guardianBirthDate').value = data.childGuardianBirthDate || '';
            if (data.childGuardianSexId)   document.getElementById('guardianSex').value   = data.childGuardianSexId;
            if (data.childGuardianStateId) document.getElementById('guardianState').value  = data.childGuardianStateId;
            state.childGuardianIdNumber = data.childGuardianIdNumber;
            state.childGuardianName     = data.childGuardianName;
            state.guardianPatientId     = data.guardianPatientId;
            state.relationshipId        = data.relationshipId;

            // Buscar menores registrados del representante
            let minors = [];
            try {
                const minorsResp = await fetch(`/Appointment/GetMinorsByGuardian?guardianPatientId=${data.guardianPatientId}`);
                minors = await minorsResp.json();
            } catch { /* lista vacía */ }

            if (Array.isArray(minors) && minors.length > 0) {
                document.getElementById('bannerGuardianName').textContent = data.childGuardianName || '—';
                document.getElementById('bannerGuardianId').textContent   = idNumber;
                renderMinorsList(minors);
                goToStep('step-4c');
            } else {
                state.isExisting       = 'no';
                state.step6BackTarget  = 'step-5b';
                state.step5bBackTarget = 'step-4b';
                document.getElementById('patientBadge').classList.add('d-none');
                goToStep('step-5b');
            }
        } else {
            document.getElementById('guardianSection').classList.add('d-none');
            document.getElementById('patientBadge').classList.remove('d-none');
            goToStep('step-6');
        }
    } catch {
        if (errEl) errEl.textContent = 'Error al consultar. Intente nuevamente.';
    } finally {
        btn.disabled = false;
        btn.innerHTML = 'Siguiente <i class="fas fa-arrow-right"></i>';
    }
});

