<script>
/* ================================================================
   DATOS DEL WIZARD
================================================================ */

/* ================================================================
   ESTADO GLOBAL
================================================================ */
const state = {
    specialtyId:        null,
    specialty:          '',
    clinicId:           null,
    clinicName:         '',
    isExisting:         null,   // 'yes' | 'no'
    patientType:        null,   // 'adult' | 'minor'
    patientName:        '',
    idNumber:           '',
    guardianPatientId:  null,
    step6BackTarget:    'step-5a',
    step5bBackTarget:   'step-3'
};

const PROGRESS = {
    'step-1': 12, 'step-2': 24, 'step-4a': 38,
    'step-3': 50, 'step-4b': 50, 'step-4c': 57,
    'step-5a': 64, 'step-5b': 64,
    'step-6': 78, 'step-7': 90, 'step-8': 100
};

let currentStep = 'step-1';

/* ================================================================
   NAVEGACIÓN
================================================================ */
function goToStep(next) {
    document.getElementById('progressFill').style.width = PROGRESS[next] + '%';
    document.getElementById(currentStep).classList.remove('active');
    document.getElementById(next).classList.add('active');
    currentStep = next;
}

function goBack(target) { goToStep(target); }

/* ================================================================
   HELPERS — validación
================================================================ */
function markInvalid(id) {
    const el = document.getElementById(id);
    el.classList.add('is-invalid');
    el.addEventListener('input', () => el.classList.remove('is-invalid'), { once: true });
    el.addEventListener('change', () => el.classList.remove('is-invalid'), { once: true });
    return false;
}
function reqVal(id) {
    const val = document.getElementById(id).value.trim();
    if (!val) { markInvalid(id); return null; }
    return val;
}

/* ================================================================
   HELPERS — poblar selects
================================================================ */
function populateSelect(selectId, items, placeholder) {
    const sel = document.getElementById(selectId);
    sel.innerHTML = `<option value="">${placeholder}</option>`;
    items.forEach(item => {
        const opt = document.createElement('option');
        opt.value = opt.textContent = item;
        sel.appendChild(opt);
    });
}


/* ================================================================
   RADIO BUTTONS — feedback visual
================================================================ */
function bindRadioGroup(name) {
    document.querySelectorAll(`input[name="${name}"]`).forEach(r => {
        r.addEventListener('change', function () {
            document.querySelectorAll(`input[name="${name}"]`).forEach(x =>
                x.closest('.wz-radio-opt').classList.remove('selected'));
            this.closest('.wz-radio-opt').classList.add('selected');
        });
    });
}
bindRadioGroup('existingPt');
bindRadioGroup('patType');

/* ── Campos cédula: solo números, máx 9 dígitos ── */
['existingIdNumber', 'adultIdNumber', 'guardianIdNumber'].forEach(id => {
    const el = document.getElementById(id);
    el.addEventListener('keypress', e => { if (!/\d/.test(e.key)) e.preventDefault(); });
    el.addEventListener('input',    () => { el.value = el.value.replace(/\D/g, '').slice(0, 9); });
    el.addEventListener('paste',    e => {
        e.preventDefault();
        const clean = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 9);
        el.value = clean;
    });
});

/* ── Campos de texto: mayúsculas, sin acentos (solo Ñ), sin caracteres especiales ── */
(function () {
    const ACCENT = {
        'á':'A','à':'A','ä':'A','â':'A','ã':'A','Á':'A','À':'A','Ä':'A','Â':'A','Ã':'A',
        'é':'E','è':'E','ë':'E','ê':'E','É':'E','È':'E','Ë':'E','Ê':'E',
        'í':'I','ì':'I','ï':'I','î':'I','Í':'I','Ì':'I','Ï':'I','Î':'I',
        'ó':'O','ò':'O','ö':'O','ô':'O','õ':'O','Ó':'O','Ò':'O','Ö':'O','Ô':'O','Õ':'O',
        'ú':'U','ù':'U','ü':'U','û':'U','Ú':'U','Ù':'U','Ü':'U','Û':'U',
        'ñ':'Ñ'
    };

    function sanitize(val) {
        return val
            .split('').map(c => ACCENT[c] ?? c).join('')
            .toUpperCase()
            .replace(/[^A-ZÑ0-9 .,\-#()/':]/g, '');
    }

    function bindText(id) {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('input', () => {
            const pos = el.selectionStart;
            el.value = sanitize(el.value);
            try { el.setSelectionRange(pos, pos); } catch (_) {}
        });
        el.addEventListener('paste', e => {
            e.preventDefault();
            const raw  = (e.clipboardData || window.clipboardData).getData('text') || '';
            const pre  = el.value.slice(0, el.selectionStart);
            const post = el.value.slice(el.selectionEnd);
            el.value   = sanitize(pre + raw + post);
        });
    }

    ['adultName', 'adultAddress', 'minorName', 'guardianName', 'guardianAddress', 'txtSymptoms']
        .forEach(bindText);

    /* ── Campos teléfono: solo dígitos y guiones ── */
    function bindPhone(id) {
        const el = document.getElementById(id);
        if (!el) return;
        const clean = v => v.replace(/[^0-9\-]/g, '');
        el.addEventListener('keypress', e => { if (!/[\d\-]/.test(e.key)) e.preventDefault(); });
        el.addEventListener('input',    () => { el.value = clean(el.value); });
        el.addEventListener('paste',    e => {
            e.preventDefault();
            el.value = clean((e.clipboardData || window.clipboardData).getData('text') || '');
        });
    }

    ['adultPhone', 'guardianPhone'].forEach(bindPhone);
})();

