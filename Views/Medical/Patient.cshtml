@model Medycally.Models.AppointmentDetailModel
@{
    ViewData["Title"]  = "Atención al Paciente";
    var history        = ViewBag.History        as List<Medycally.Models.MedicalAttentionModel> ?? [];
    var existing       = ViewBag.Existing       as Medycally.Models.MedicalAttentionModel;
    var patientHistory = ViewBag.PatientHistory as Medycally.Models.PatientHistoryModel;
    var patientId      = (int)(ViewBag.PatientId ?? 0);
    var isMinor        = Model.PatientTypeId == 2;
    var fromAttended   = Context.Request.Query["from"] == "attended";
    // Cuando ya hay atención guardada, las tarjetas de Cita y Atención inician vacías;
    // se llenan al hacer clic en un ítem del acordeón de Consultas.
    var hasExisting    = existing != null;
    var medPerms       = Permissions.GetPermissions(User, "/Medical/Index");
    var patPerms       = Permissions.GetPermissions(User, "/Patient/Index");
    var canSaveAttention = hasExisting ? medPerms.CanEdit : medPerms.CanCreate;

    string sel(int field, int val) => field == val ? "checked" : "";
}

<!-- Back link -->
<div class="mb-3">
    @if (fromAttended)
    {
        <a href="/Medical/AttendedPatients" class="text-decoration-none text-muted">
            <i class="fas fa-arrow-left me-1"></i>Volver a Pacientes Atendidos
        </a>
    }
    else
    {
        <a href="/Medical/Index" class="text-decoration-none text-muted">
            <i class="fas fa-arrow-left me-1"></i>Volver a la Cola
        </a>
    }
</div>

<!-- Status banner -->
@if (Model.AppointmentStatusId == 4)
{
    <div class="alert alert-info d-flex align-items-center py-2 mb-3">
        <i class="fas fa-user-clock me-2"></i>
        <strong>En Atención</strong> &nbsp;— cita #@Model.AppointmentId
    </div>
}

<div class="row g-4">

    <!-- ======================== LEFT: Patient + Appointment info ======================== -->
    <div class="col-lg-4">

        <!-- Patient card -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-primary text-white py-2">
                <i class="fas fa-user me-2"></i>Datos del Paciente
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <span class="fw-bold fs-5">@(!string.IsNullOrEmpty(Model.PatientName) ? Model.PatientName : "—")</span>
                    @if (isMinor)
                    {
                        <span class="badge bg-warning text-dark ms-2">Menor</span>
                    }
                </div>
                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted pe-2">Cédula</td>
                        <td>@(Model.PatientIdNumber > 0 ? $"V-{Model.PatientIdNumber}" : "Sin cédula")</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Edad</td>
                        <td>@Model.PatientAge años</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Sexo</td>
                        <td>@(Model.PatientSexName ?? "—")</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.PatientPhone))
                    {
                        <tr>
                            <td class="text-muted pe-2">Teléfono</td>
                            <td>@Model.PatientPhone</td>
                        </tr>
                    }
                    @if (!string.IsNullOrEmpty(Model.PatientAddress))
                    {
                        <tr>
                            <td class="text-muted pe-2">Dirección</td>
                            <td>@Model.PatientAddress</td>
                        </tr>
                    }
                    @if (Model.PatientBirthDate.HasValue)
                    {
                        <tr>
                            <td class="text-muted pe-2">Nacimiento</td>
                            <td>@Model.PatientBirthDate.Value.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </table>

                @if (isMinor && !string.IsNullOrEmpty(Model.ChildGuardianName))
                {
                    <hr class="my-2" />
                    <div class="small text-muted mb-1"><i class="fas fa-user-friends me-1"></i>Representante</div>
                    <div class="fw-semibold">@Model.ChildGuardianName</div>
                    @if (!string.IsNullOrEmpty(Model.RelationshipName))
                    {
                        <div class="small text-muted">@Model.RelationshipName</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ChildGuardianPhone))
                    {
                        <div class="small"><i class="fas fa-phone me-1"></i>@Model.ChildGuardianPhone</div>
                    }
                }
            </div>
        </div>

        <!-- Appointment card -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white py-2">
                <i class="fas fa-calendar-check me-2"></i>Datos de la Cita
            </div>
            <div class="card-body">
                @{
                    var initialReason   = hasExisting ? "" : (Model.ReasonName ?? "");
                    var initialSymptoms = hasExisting ? "" : (Model.Symptoms   ?? "");
                    var showReasonRow   = !string.IsNullOrEmpty(initialReason);
                    var showSymptomsBox = !string.IsNullOrEmpty(initialSymptoms);
                }
                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted pe-2">Especialidad</td>
                        <td class="fw-semibold" id="citaSpecialty">@(hasExisting ? "—" : (Model.SpecialtyName ?? "—"))</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Médico</td>
                        <td id="citaDoctor">@(hasExisting ? "—" : (Model.DoctorName ?? "—"))</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Fecha</td>
                        <td id="citaDate">@(hasExisting ? "—" : Model.AppointmentDate.ToString("dd/MM/yyyy"))</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Hora</td>
                        <td id="citaTime">@(hasExisting ? "—" : (Model.AppointmentTime ?? "—"))</td>
                    </tr>
                    <tr id="citaReasonRow" class="@(showReasonRow ? "" : "d-none")">
                        <td class="text-muted pe-2">Motivo</td>
                        <td id="citaReason">@initialReason</td>
                    </tr>
                </table>

                <div id="citaSymptomsBox" class="mt-2 p-2 bg-light rounded small @(showSymptomsBox ? "" : "d-none")">
                    <div class="text-muted mb-1"><i class="fas fa-comment-medical me-1"></i>Síntomas referidos</div>
                    <div id="citaSymptoms">@initialSymptoms</div>
                </div>
            </div>
        </div>

    </div>

    <!-- ======================== RIGHT: History + New Attention ======================== -->
    <div class="col-lg-8">

        <!-- Tabs: Atención | Consultas | Antecedentes -->
        @{
            var ph     = patientHistory;
            bool hasAnt = ph != null;
            var atencionTab = new {
                Active = !hasExisting ? "active" : "",
                Pane   = !hasExisting ? "show active" : "",
                Title  = hasExisting ? "Editar Atención" : "Nueva Atención"
            };
            var consultasTab = new {
                Active = hasExisting ? "active" : "",
                Pane   = hasExisting ? "show active" : ""
            };
        }
        <ul class="nav nav-tabs mb-0" id="medTabs" role="tablist">
            @if (!hasExisting)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link @atencionTab.Active" id="tab-atencion" data-bs-toggle="tab"
                            data-bs-target="#pane-atencion" type="button" role="tab">
                        <i class="fas fa-file-medical-alt me-1"></i>@atencionTab.Title
                    </button>
                </li>
            }
            <li class="nav-item" role="presentation">
                <button class="nav-link @consultasTab.Active" id="tab-consultas" data-bs-toggle="tab"
                        data-bs-target="#pane-consultas" type="button" role="tab">
                    <i class="fas fa-notes-medical me-1"></i>Consultas
                    <span class="badge bg-primary rounded-pill ms-1">@history.Count</span>
                </button>
            </li>
            @if (hasExisting)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-atencion" data-bs-toggle="tab"
                            data-bs-target="#pane-atencion" type="button" role="tab">
                        <i class="fas fa-file-medical-alt me-1"></i>@atencionTab.Title
                    </button>
                </li>
            }
            @if (patientId > 0)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-antecedentes" data-bs-toggle="tab"
                            data-bs-target="#pane-antecedentes" type="button" role="tab">
                        <i class="fas fa-clipboard-list me-1"></i>Antecedentes
                        @if (hasAnt)
                        {
                            <span class="badge bg-success rounded-pill ms-1">✓</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary rounded-pill ms-1">—</span>
                        }
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content border border-top-0 rounded-bottom shadow-sm mb-4">

            <!-- ── TAB ATENCIÓN ── -->
            <div class="tab-pane fade @atencionTab.Pane p-3" id="pane-atencion" role="tabpanel">
                <input type="hidden" id="attentionId"   value="@(existing?.AttentionId ?? 0)" />
                <input type="hidden" id="appointmentId" value="@Model.AppointmentId" />

                @{
                    // Si hay atención guardada, el formulario inicia vacío; sólo se carga
                    // al hacer clic en una consulta del acordeón.
                    string val(string? s) => hasExisting ? "" : (s ?? "");
                }
                <div class="mb-3">
                    <label class="form-label fw-semibold">Motivo de Consulta</label>
                    <textarea class="form-control" id="txtChiefComplaint" rows="2"
                              placeholder="Motivo principal por el que acude el paciente...">@val(existing?.ChiefComplaint)</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Enfermedad Actual</label>
                    <textarea class="form-control" id="txtCurrentIlness" rows="3"
                              placeholder="Descripción de la enfermedad actual...">@val(existing?.CurrentIlness)</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Diagnóstico <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="txtDiagnosis" rows="3"
                              placeholder="Descripción del diagnóstico médico...">@val(existing?.Diagnosis)</textarea>
                    <div class="invalid-feedback" id="diagnosisError"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Exámenes</label>
                    <textarea class="form-control" id="txtLaboratoryTests" rows="2"
                              placeholder="Exámenes de laboratorio o estudios indicados...">@val(existing?.LaboratoryTests)</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Órdenes Médicas</label>
                    <textarea class="form-control" id="txtTestRequisition" rows="2"
                              placeholder="Órdenes médicas y solicitudes...">@val(existing?.TestRequisition)</textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Tratamiento <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="txtTreatment" rows="3"
                              placeholder="Plan de tratamiento indicado...">@val(existing?.Treatment)</textarea>
                    <div class="invalid-feedback" id="treatmentError"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notas adicionales</label>
                    <textarea class="form-control" id="txtNotes" rows="2"
                              placeholder="Observaciones, indicaciones adicionales...">@val(existing?.Notes)</textarea>
                </div>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @if (canSaveAttention)
                    {
                        <button type="button" class="btn btn-success px-4" id="btnSaveAttention"
                                onclick="confirmAction('atencion')">
                            <i class="fas fa-save me-2"></i>Guardar Atención
                        </button>
                    }
                    <a id="btnMedicalReport"
                       href="/Medical/MedicalReport/@Model.AppointmentId"
                       target="_blank"
                       class="btn btn-outline-primary px-4 @(existing != null ? "" : "disabled pe-none")"
                       @(existing != null ? "" : Html.Raw("aria-disabled=\"true\" tabindex=\"-1\""))>
                        <i class="fas fa-file-medical me-2"></i>Informe Médico
                    </a>
                    <span id="saveStatus" class="small text-muted"></span>
                </div>
            </div><!-- /pane-atencion -->

            <!-- ── TAB CONSULTAS ── -->
            <div class="tab-pane fade @consultasTab.Pane p-0" id="pane-consultas" role="tabpanel">
                @if (history.Count == 0)
                {
                    <div class="text-center py-5 text-muted small">
                        <i class="fas fa-file-medical fa-2x mb-2 opacity-25 d-block"></i>
                        Sin atenciones previas registradas.
                    </div>
                }
                else
                {
                    <div class="accordion accordion-flush" id="historyAccordion">
                        @for (int i = 0; i < history.Count; i++)
                        {
                            var h     = history[i];
                            var colId = $"hist-{i}";
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed history-toggle"
                                            type="button" data-bs-toggle="collapse"
                                            data-bs-target="#@colId"
                                            data-history-index="@i">
                                        <div class="d-flex w-100 align-items-center gap-3 flex-wrap">
                                            <span class="fw-semibold">@h.AttentionDate.ToString("dd/MM/yyyy")</span>
                                            @if (!string.IsNullOrEmpty(h.PatientName))
                                            {
                                                <span class="badge bg-warning text-dark">@h.PatientName</span>
                                            }
                                            <span class="text-muted small">
                                                @(h.SpecialtyName ?? "") &nbsp;·&nbsp; @(h.DoctorName ?? "")
                                            </span>
                                        </div>
                                    </button>
                                </h2>
                                <div id="@colId" class="accordion-collapse collapse" data-bs-parent="#historyAccordion">
                                    <div class="accordion-body small">
                                        @if (!string.IsNullOrEmpty(h.Symptoms))
                                        {
                                            <div class="mb-2 p-2 bg-light rounded">
                                                <span class="text-muted fw-semibold">Síntomas:&nbsp;</span>@h.Symptoms
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(h.ChiefComplaint))
                                        {
                                            <div class="mb-2">
                                                <div class="text-muted fw-semibold mb-1">Motivo de Consulta</div>
                                                <div class="p-2 bg-light rounded">@h.ChiefComplaint</div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(h.CurrentIlness))
                                        {
                                            <div class="mb-2">
                                                <div class="text-muted fw-semibold mb-1">Enfermedad Actual</div>
                                                <div class="p-2 bg-light rounded">@h.CurrentIlness</div>
                                            </div>
                                        }
                                        <div class="mb-2">
                                            <div class="text-muted fw-semibold mb-1">Diagnóstico</div>
                                            <div class="p-2 bg-light rounded">@h.Diagnosis</div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(h.LaboratoryTests))
                                        {
                                            <div class="mb-2">
                                                <div class="text-muted fw-semibold mb-1">Exámenes</div>
                                                <div class="p-2 bg-light rounded">@h.LaboratoryTests</div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrEmpty(h.TestRequisition))
                                        {
                                            <div class="mb-2">
                                                <div class="text-muted fw-semibold mb-1">Órdenes Médicas</div>
                                                <div class="p-2 bg-light rounded">@h.TestRequisition</div>
                                            </div>
                                        }
                                        <div class="mb-2">
                                            <div class="text-muted fw-semibold mb-1">Tratamiento</div>
                                            <div class="p-2 bg-light rounded">@h.Treatment</div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(h.Notes))
                                        {
                                            <div>
                                                <div class="text-muted fw-semibold mb-1">Notas adicionales</div>
                                                <div class="p-2 bg-light rounded">@h.Notes</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- ── TAB ANTECEDENTES ── -->
            @if (patientId > 0)
            {
                <div class="tab-pane fade p-3" id="pane-antecedentes" role="tabpanel">
                    <input type="hidden" id="phPatientIdMed" value="@patientId" />

                                <!-- Condiciones personales -->
                                <div class="mb-3">
                                    <div class="fw-semibold small text-muted mb-2">Antecedentes Médicos Personales</div>
                                    <div class="row g-2 small">
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkHyp" @(ph?.HasHypertension==true?"checked":"") /><label class="form-check-label" for="mChkHyp">Hipertensión</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkDia" @(ph?.HasDiabetes==true?"checked":"") /><label class="form-check-label" for="mChkDia">Diabetes</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkHrt" @(ph?.HasHeartDisease==true?"checked":"") /><label class="form-check-label" for="mChkHrt">Enf. cardíacas</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkAsm" @(ph?.HasAsthmaRespiratory==true?"checked":"") /><label class="form-check-label" for="mChkAsm">Asma / Resp.</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkThy" @(ph?.HasThyroidDisease==true?"checked":"") /><label class="form-check-label" for="mChkThy">Tiroides</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkRen" @(ph?.HasRenalDisease==true?"checked":"") /><label class="form-check-label" for="mChkRen">Enf. renales</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkAnx" @(ph?.HasAnxietyDepression==true?"checked":"") /><label class="form-check-label" for="mChkAnx">Ansiedad/Depresión</label></div></div>
                                        <div class="col-6 col-lg-4"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkCan" @(ph?.HasCancer==true?"checked":"") onchange="document.getElementById('mCancerRow').classList.toggle('d-none',!this.checked)" /><label class="form-check-label" for="mChkCan">Cáncer</label></div></div>
                                    </div>
                                    <div class="mt-2 @(ph?.HasCancer==true?"":"d-none")" id="mCancerRow">
                                        <input type="text" class="form-control form-control-sm" id="mTxtCancerDetail" placeholder="Tipo de cáncer" maxlength="200" value="@(ph?.CancerDetail??"")" />
                                    </div>
                                </div>
                                <div class="row g-3 mb-3 small">
                                    <div class="col-md-6">
                                        <label class="fw-semibold">Cirugías previas</label>
                                        <textarea class="form-control form-control-sm" id="mTxtSurgeries" rows="2" maxlength="500">@(ph?.PreviousSurgeries??"")</textarea>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="fw-semibold">Hospitalizaciones recientes</label>
                                        <textarea class="form-control form-control-sm" id="mTxtHospitalizations" rows="2" maxlength="500">@(ph?.RecentHospitalizations??"")</textarea>
                                    </div>
                                </div>

                                <!-- Alergias -->
                                <div class="mb-3">
                                    <div class="fw-semibold small text-muted mb-2">Alergias</div>
                                    <div class="row g-2 small">
                                        <div class="col-md-4">
                                            <label class="form-label mb-1 small">Medicamentos</label>
                                            <input type="text" class="form-control form-control-sm" id="mTxtDrugAllergies" maxlength="300" value="@(ph?.DrugAllergies??"")" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label mb-1 small">Alimentos</label>
                                            <input type="text" class="form-control form-control-sm" id="mTxtFoodAllergies" maxlength="300" value="@(ph?.FoodAllergies??"")" />
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label mb-1 small">Otras</label>
                                            <input type="text" class="form-control form-control-sm" id="mTxtOtherAllergies" maxlength="300" value="@(ph?.OtherAllergies??"")" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Medicamentos actuales -->
                                <div class="mb-3 small">
                                    <label class="fw-semibold text-muted">Medicamentos Actuales</label>
                                    <textarea class="form-control form-control-sm" id="mTxtCurrentMeds" rows="2" maxlength="1000">@(ph?.CurrentMedications??"")</textarea>
                                </div>

                                <!-- Antecedentes familiares -->
                                <div class="mb-3">
                                    <div class="fw-semibold small text-muted mb-2">Antecedentes Familiares</div>
                                    <div class="row g-2 small">
                                        <div class="col-6 col-lg-3"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkFamD" @(ph?.FamilyDiabetes==true?"checked":"") /><label class="form-check-label" for="mChkFamD">Diabetes</label></div></div>
                                        <div class="col-6 col-lg-3"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkFamC" @(ph?.FamilyCancer==true?"checked":"") /><label class="form-check-label" for="mChkFamC">Cáncer</label></div></div>
                                        <div class="col-6 col-lg-3"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkFamH" @(ph?.FamilyHeartDisease==true?"checked":"") /><label class="form-check-label" for="mChkFamH">Enf. corazón</label></div></div>
                                        <div class="col-6 col-lg-3"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkFamP" @(ph?.FamilyHypertension==true?"checked":"") /><label class="form-check-label" for="mChkFamP">Presión alta</label></div></div>
                                    </div>
                                    <input type="text" class="form-control form-control-sm mt-2 small" id="mTxtFamilyOthers" placeholder="Otros antecedentes familiares" maxlength="300" value="@(ph?.FamilyOthers??"")" />
                                </div>

                                <!-- Hábitos -->
                                <div class="mb-3 small">
                                    <div class="fw-semibold text-muted mb-2">Hábitos y Estilo de Vida</div>
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="d-block mb-1">Tabaco</label>
                                            <div class="d-flex gap-3 flex-wrap">
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mSmoking" id="mSmkN" value="0" @sel(ph?.SmokingStatus??0,0) /><label class="form-check-label" for="mSmkN">Nunca</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mSmoking" id="mSmkE" value="1" @sel(ph?.SmokingStatus??0,1) /><label class="form-check-label" for="mSmkE">Ex-fumador</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mSmoking" id="mSmkA" value="2" @sel(ph?.SmokingStatus??0,2) onchange="document.getElementById('mSmkAmtRow').classList.toggle('d-none',this.value!='2')" /><label class="form-check-label" for="mSmkA">Activo</label></div>
                                            </div>
                                            <div class="mt-1 @(ph?.SmokingStatus==2?"":"d-none")" id="mSmkAmtRow"><input type="text" class="form-control form-control-sm" id="mTxtSmkAmt" placeholder="Cantidad/día" maxlength="50" value="@(ph?.SmokingDailyAmount??"")" /></div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="d-block mb-1">Alcohol</label>
                                            <div class="d-flex gap-3 flex-wrap">
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mAlcohol" id="mAlcN" value="0" @sel(ph?.AlcoholStatus??0,0) /><label class="form-check-label" for="mAlcN">Nunca</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mAlcohol" id="mAlcO" value="1" @sel(ph?.AlcoholStatus??0,1) /><label class="form-check-label" for="mAlcO">Ocasional</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mAlcohol" id="mAlcF" value="2" @sel(ph?.AlcoholStatus??0,2) /><label class="form-check-label" for="mAlcF">Frecuente</label></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="d-block mb-1">Actividad física</label>
                                            <div class="d-flex gap-3 flex-wrap">
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mPhysical" id="mPhyS" value="0" @sel(ph?.PhysicalActivity??0,0) /><label class="form-check-label" for="mPhyS">Sedentario</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mPhysical" id="mPhyM" value="1" @sel(ph?.PhysicalActivity??0,1) /><label class="form-check-label" for="mPhyM">Moderado</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mPhysical" id="mPhyA" value="2" @sel(ph?.PhysicalActivity??0,2) /><label class="form-check-label" for="mPhyA">Activo</label></div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="d-block mb-1">Sustancias / drogas</label>
                                            <div class="d-flex gap-3 flex-wrap">
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mDrug" id="mDrugN" value="0" @(ph?.DrugUse==true?"":"checked") /><label class="form-check-label" for="mDrugN">No</label></div>
                                                <div class="form-check"><input class="form-check-input" type="radio" name="mDrug" id="mDrugY" value="1" @(ph?.DrugUse==true?"checked":"") /><label class="form-check-label" for="mDrugY">Sí</label></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Revisión sistemas -->
                                <div class="mb-3">
                                    <div class="fw-semibold small text-muted mb-2">Revisión por Sistemas</div>
                                    <div class="row g-2 small">
                                        <div class="col-sm-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkWL" @(ph?.HasWeightLoss==true?"checked":"") /><label class="form-check-label" for="mChkWL">Pérdida de peso inexplicable</label></div></div>
                                        <div class="col-sm-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkFF" @(ph?.HasFrequentFever==true?"checked":"") /><label class="form-check-label" for="mChkFF">Fiebre frecuente</label></div></div>
                                        <div class="col-sm-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkHH" @(ph?.HasHeadache==true?"checked":"") /><label class="form-check-label" for="mChkHH">Dolor de cabeza persistente</label></div></div>
                                        <div class="col-sm-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkVH" @(ph?.HasVisionHearingChange==true?"checked":"") /><label class="form-check-label" for="mChkVH">Cambios en visión o audición</label></div></div>
                                        <div class="col-sm-6"><div class="form-check"><input class="form-check-input" type="checkbox" id="mChkBD" @(ph?.HasBreathingDifficulty==true?"checked":"") /><label class="form-check-label" for="mChkBD">Dificultad para respirar</label></div></div>
                                    </div>
                                </div>

                    @if (patPerms.CanEdit)
                    {
                        <div class="d-flex align-items-center gap-2 mt-3">
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnSaveMedHistory" onclick="confirmAction('antecedentes')">
                                <i class="fas fa-save me-1"></i>Guardar Antecedentes
                            </button>
                            <span id="medHistStatus" class="small text-muted"></span>
                        </div>
                    }
                </div><!-- /pane-antecedentes -->
            }

        </div><!-- /tab-content -->

    </div>
</div>

<!-- Modal confirmación -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmModalTitle">Confirmar guardado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirmModalBody" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnConfirmAction" data-bs-dismiss="modal">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="toast" class="toast align-items-center text-white border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<style>
    .accordion-button:not(.collapsed) { background: #f0f9ff; color: #0a58ca; }
</style>

@section Scripts {
<script>
    let _pendingAction = null;

    const hasExistingAttention = @(hasExisting ? "true" : "false");
    const historyItems         = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(history));

    // Cuando hay atención guardada, ambas tarjetas inician vacías y se llenan al
    // hacer clic en un ítem del acordeón de Consultas; además se cambia a la
    // pestaña Atención para mostrar los datos cargados.
    if (hasExistingAttention) {
        document.querySelectorAll('.history-toggle').forEach(btn => {
            btn.addEventListener('click', () => {
                const idx = parseInt(btn.dataset.historyIndex ?? '-1', 10);
                if (idx < 0) return;
                loadHistoryIntoCards(idx);
                const atencionTab = document.getElementById('tab-atencion');
                if (atencionTab) bootstrap.Tab.getOrCreateInstance(atencionTab).show();
            });
        });
    }

    function loadHistoryIntoCards(idx) {
        const h = historyItems[idx];
        if (!h) return;

        // Tarjeta Datos de la Cita
        document.getElementById('citaSpecialty').textContent = h.SpecialtyName || '—';
        document.getElementById('citaDoctor').textContent    = h.DoctorName    || '—';
        document.getElementById('citaDate').textContent      = h.AppointmentDate
            ? new Date(h.AppointmentDate).toLocaleDateString('es-VE', { day: '2-digit', month: '2-digit', year: 'numeric' })
            : '—';
        document.getElementById('citaTime').textContent      = '—';

        // El SP del historial no trae ReasonName; ocultamos la fila.
        document.getElementById('citaReasonRow').classList.add('d-none');

        const symBox = document.getElementById('citaSymptomsBox');
        if (h.Symptoms) {
            document.getElementById('citaSymptoms').textContent = h.Symptoms;
            symBox.classList.remove('d-none');
        } else {
            symBox.classList.add('d-none');
        }

        // Tarjeta Atención
        document.getElementById('txtChiefComplaint').value  = h.ChiefComplaint  || '';
        document.getElementById('txtCurrentIlness').value   = h.CurrentIlness   || '';
        document.getElementById('txtDiagnosis').value       = h.Diagnosis       || '';
        document.getElementById('txtLaboratoryTests').value = h.LaboratoryTests || '';
        document.getElementById('txtTestRequisition').value = h.TestRequisition || '';
        document.getElementById('txtTreatment').value       = h.Treatment       || '';
        document.getElementById('txtNotes').value           = h.Notes           || '';
    }

    const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
    const toast        = new bootstrap.Toast(document.getElementById('toast'), { delay: 3500 });

    function showToast(message, success) {
        const el = document.getElementById('toast');
        el.classList.remove('bg-success', 'bg-danger');
        el.classList.add(success ? 'bg-success' : 'bg-danger');
        document.getElementById('toastMessage').textContent = message;
        toast.show();
    }

    document.getElementById('btnConfirmAction').addEventListener('click', function () {
        if (_pendingAction) { _pendingAction(); _pendingAction = null; }
    });

    function confirmAction(type) {
        const body = document.getElementById('confirmModalBody');
        if (type === 'antecedentes') {
            body.textContent = '¿Desea guardar los antecedentes del paciente?';
            _pendingAction   = saveMedHistory;
        } else {
            body.textContent = '¿Desea guardar la atención médica?';
            _pendingAction   = saveAttention;
        }
        confirmModal.show();
    }

    async function saveMedHistory() {
        const patientId = parseInt(document.getElementById('phPatientIdMed')?.value ?? '0');
        if (!patientId) return;

        const payload = {
            patientId:              patientId,
            hasHypertension:        document.getElementById('mChkHyp').checked,
            hasDiabetes:            document.getElementById('mChkDia').checked,
            hasHeartDisease:        document.getElementById('mChkHrt').checked,
            hasAsthmaRespiratory:   document.getElementById('mChkAsm').checked,
            hasThyroidDisease:      document.getElementById('mChkThy').checked,
            hasRenalDisease:        document.getElementById('mChkRen').checked,
            hasAnxietyDepression:   document.getElementById('mChkAnx').checked,
            hasCancer:              document.getElementById('mChkCan').checked,
            cancerDetail:           document.getElementById('mTxtCancerDetail').value.trim() || null,
            previousSurgeries:      document.getElementById('mTxtSurgeries').value.trim() || null,
            recentHospitalizations: document.getElementById('mTxtHospitalizations').value.trim() || null,
            drugAllergies:          document.getElementById('mTxtDrugAllergies').value.trim() || null,
            foodAllergies:          document.getElementById('mTxtFoodAllergies').value.trim() || null,
            otherAllergies:         document.getElementById('mTxtOtherAllergies').value.trim() || null,
            currentMedications:     document.getElementById('mTxtCurrentMeds').value.trim() || null,
            familyDiabetes:         document.getElementById('mChkFamD').checked,
            familyCancer:           document.getElementById('mChkFamC').checked,
            familyHeartDisease:     document.getElementById('mChkFamH').checked,
            familyHypertension:     document.getElementById('mChkFamP').checked,
            familyOthers:           document.getElementById('mTxtFamilyOthers').value.trim() || null,
            smokingStatus:          parseInt(document.querySelector('input[name="mSmoking"]:checked')?.value ?? '0'),
            smokingDailyAmount:     document.getElementById('mTxtSmkAmt').value.trim() || null,
            alcoholStatus:          parseInt(document.querySelector('input[name="mAlcohol"]:checked')?.value ?? '0'),
            physicalActivity:       parseInt(document.querySelector('input[name="mPhysical"]:checked')?.value ?? '0'),
            drugUse:                document.querySelector('input[name="mDrug"]:checked')?.value === '1',
            hasWeightLoss:          document.getElementById('mChkWL').checked,
            hasFrequentFever:       document.getElementById('mChkFF').checked,
            hasHeadache:            document.getElementById('mChkHH').checked,
            hasVisionHearingChange: document.getElementById('mChkVH').checked,
            hasBreathingDifficulty: document.getElementById('mChkBD').checked
        };

        const btn    = document.getElementById('btnSaveMedHistory');
        const status = document.getElementById('medHistStatus');
        btn.disabled = true;
        status.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

        try {
            const res = await fetch('/Patient/SaveHistory', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload)
            });
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                throw new Error(err.message ?? 'Error al guardar los antecedentes.');
            }
            status.innerHTML = '';
            showToast('Antecedentes actualizados correctamente.', true);
        } catch (e) {
            status.innerHTML = '';
            showToast(e.message ?? 'Error al guardar los antecedentes.', false);
        } finally {
            btn.disabled = false;
        }
    }

    async function saveAttention() {
        const diagnosis = document.getElementById('txtDiagnosis').value.trim();
        const treatment = document.getElementById('txtTreatment').value.trim();
        let valid = true;

        document.getElementById('txtDiagnosis').classList.remove('is-invalid');
        document.getElementById('txtTreatment').classList.remove('is-invalid');

        if (!diagnosis) {
            document.getElementById('txtDiagnosis').classList.add('is-invalid');
            document.getElementById('diagnosisError').textContent = 'El diagnóstico es requerido.';
            valid = false;
        }
        if (!treatment) {
            document.getElementById('txtTreatment').classList.add('is-invalid');
            document.getElementById('treatmentError').textContent = 'El tratamiento es requerido.';
            valid = false;
        }
        if (!valid) return;

        const payload = {
            attentionId:     parseInt(document.getElementById('attentionId').value),
            appointmentId:   parseInt(document.getElementById('appointmentId').value),
            chiefComplaint:  document.getElementById('txtChiefComplaint').value.trim()  || null,
            currentIlness:   document.getElementById('txtCurrentIlness').value.trim()   || null,
            diagnosis:       diagnosis,
            laboratoryTests: document.getElementById('txtLaboratoryTests').value.trim() || null,
            testRequisition: document.getElementById('txtTestRequisition').value.trim() || null,
            treatment:       treatment,
            notes:           document.getElementById('txtNotes').value.trim()           || null
        };

        const btn        = document.getElementById('btnSaveAttention');
        const wasNew     = parseInt(document.getElementById('attentionId').value, 10) === 0;
        btn.disabled     = true;
        document.getElementById('saveStatus').innerHTML =
            '<span class="spinner-border spinner-border-sm me-1"></span>Guardando...';

        try {
            const res = await fetch('/Medical/SaveAttention', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message ?? 'Error al guardar la atención.');

            document.getElementById('attentionId').value = data.attentionId;
            const rBtn = document.getElementById('btnMedicalReport');
            rBtn.classList.remove('disabled', 'pe-none');
            rBtn.removeAttribute('aria-disabled');
            rBtn.removeAttribute('tabindex');

            document.getElementById('saveStatus').innerHTML = '';
            showToast(wasNew ? 'Atención médica registrada correctamente.'
                             : 'Atención médica actualizada correctamente.', true);

            setTimeout(() => { window.location.reload(); }, 1500);
        } catch (e) {
            document.getElementById('saveStatus').innerHTML = '';
            showToast(e.message ?? 'Error al guardar la atención.', false);
        } finally {
            btn.disabled = false;
        }
    }
</script>
}
