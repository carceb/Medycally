@model List<Medycally.Models.AdminUserModel>
@{
    ViewData["Title"] = "Usuarios";
    var roles   = ViewBag.Roles   as List<Medycally.Models.SecurityRoleModel> ?? [];
    var doctors = ViewBag.Doctors as List<Medycally.Models.DoctorModel>       ?? [];
    var userPerms = Permissions.GetPermissions(User, "/Admin/User");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Usuarios del Sistema</h4>
    @if (userPerms.CanCreate)
    {
        <button class="btn btn-primary" onclick="openModal()">
            <i class="fas fa-plus me-1"></i> Nuevo Usuario
        </button>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <div class="row mb-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text text-muted"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" id="searchInput"
                           placeholder="Buscar por nombre, correo, cédula, rol..."
                           oninput="applyFilters()" />
                    <button class="btn btn-outline-secondary" type="button" onclick="clearSearch()" title="Limpiar">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover mb-0 users-table">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Usuario</th>
                        <th>Cédula</th>
                        <th>Rol</th>
                        <th>Activación</th>
                        <th>Estatus</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody id="userBody"></tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted" id="paginationInfo"></small>
            <nav><ul class="pagination pagination-sm mb-0" id="pagination"></ul></nav>
        </div>

    </div>
</div>

<!-- Save Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Nuevo Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="securityUserId" value="0" />
                <div id="newUserNotice" class="alert alert-info d-flex align-items-start" style="display:none!important">
                    <i class="fas fa-envelope me-2 mt-1"></i>
                    <span>Se enviará un correo de activación al usuario para que establezca su contraseña.</span>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nombre completo <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="userName" maxlength="150" />
                        <div class="invalid-feedback" id="nameError"></div>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Correo electrónico <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="userEmail" maxlength="150" />
                        <div class="invalid-feedback" id="emailError"></div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Cédula</label>
                        <input type="number" class="form-control" id="userIdNumber" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Rol</label>
                        <select class="form-select" id="securityRoleId" onchange="onRoleChange()">
                            @foreach (var r in roles)
                            {
                                <option value="@r.SecurityRoleId" data-name="@r.RoleName">@r.RoleName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Estatus</label>
                        <select class="form-select" id="userStatusId">
                            <option value="1">Activo</option>
                            <option value="2">Inactivo</option>
                        </select>
                    </div>
                    <div class="col-12" id="doctorRow" style="display:none">
                        <label class="form-label">Médico vinculado</label>
                        <select class="form-select" id="doctorId">
                            <option value="">— Sin médico —</option>
                            @foreach (var doc in doctors)
                            {
                                <option value="@doc.DoctorId">@doc.DoctorName</option>
                            }
                        </select>
                        <div class="form-text">Vincula este usuario con su registro de médico para filtrar su cola de atención.</div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSave" onclick="saveUser()">
                    <span id="btnSaveIcon"><i class="fas fa-paper-plane me-1"></i></span>
                    <span id="btnSaveText">Crear y enviar invitación</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Clinics Assignment Modal -->
<div class="modal fade" id="clinicsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clinicsModalTitle">Clínicas asignadas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="clinicsUserId" value="0" />
                <p class="text-muted small mb-3">Selecciona las clínicas a las que este usuario podrá acceder con su mismo usuario y contraseña.</p>
                <div class="input-group input-group-sm mb-3">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" id="clinicsSearch"
                           placeholder="Buscar clínica..." oninput="filterClinicsList()" />
                </div>
                <div id="clinicsLoading" class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary"></div>
                </div>
                <div id="clinicsChecks" class="d-none"></div>
                <div id="clinicsError" class="alert alert-danger d-none mb-0"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSaveClinics" onclick="saveUserClinics()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Eliminar Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Eliminar a <strong id="deleteName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="btnDelete" onclick="deleteUser()">Eliminar</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="toast" class="toast align-items-center text-white border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .activation-badge { display:inline-flex; align-items:center; gap:5px; font-size:.78rem; font-weight:600; padding:3px 10px; border-radius:20px; }
    .activation-active   { background:#d1fae5; color:#065f46; }
    .activation-pending  { background:#fef3c7; color:#92400e; }
</style>
<script>
    const userModal    = new bootstrap.Modal(document.getElementById('userModal'));
    const deleteModal  = new bootstrap.Modal(document.getElementById('deleteModal'));
    const clinicsModal = new bootstrap.Modal(document.getElementById('clinicsModal'));
    const toast        = new bootstrap.Toast(document.getElementById('toast'), { delay: 3500 });

    let userClinicsCache = [];

    let pendingDeleteId = 0;
    let filteredUsers   = [];
    let currentPage     = 1;
    const PAGE_SIZE     = 10;

    const allUsers   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    const allRoles   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(roles));
    const allDoctors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(doctors));

    const userPerms = {
        canCreate: @(userPerms.CanCreate ? "true" : "false"),
        canEdit:   @(userPerms.CanEdit   ? "true" : "false"),
        canDelete: @(userPerms.CanDelete ? "true" : "false")
    };

    function roleBadgeClass(roleName) {
        const lower = (roleName ?? '').toLowerCase();
        if (lower.includes('admin') || lower.includes('super')) return 'role-admin';
        if (lower.includes('médico') || lower.includes('doctor')) return 'role-manager';
        return 'role-user';
    }

    function renderTable() {
        const tbody = document.getElementById('userBody');
        const start = (currentPage - 1) * PAGE_SIZE;
        const page  = filteredUsers.slice(start, start + PAGE_SIZE);

        if (filteredUsers.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3">No se encontraron usuarios.</td></tr>';
            renderPagination();
            return;
        }

        tbody.innerHTML = page.map(u => {
            const escaped    = (u.UserName ?? '').replace(/'/g, "\\'");
            const initials   = encodeURIComponent(u.UserName ?? 'U');
            const badgeClass = roleBadgeClass(u.RoleName);
            const statusClass = u.StatusId === 1 ? 'status-active' : 'status-inactive';
            const statusLabel = u.StatusId === 1 ? 'Activo' : 'Inactivo';
            const actBadge = u.IsActivated
                ? `<span class="activation-badge activation-active"><i class="fas fa-check-circle"></i> Activado</span>`
                : `<span class="activation-badge activation-pending"><i class="fas fa-clock"></i> Pendiente</span>`;
            const resendBtn = !u.IsActivated
                ? `<button class="btn-icon" onclick="resendActivation(${u.SecurityUserId},'${escaped}')" title="Reenviar invitación"><i class="fas fa-envelope text-warning"></i></button>`
                : '';
            const isDoctorUser = !!u.DoctorId;
            let clinicsBtn = '';
            if (u.IsSuperAdmin) {
                clinicsBtn = `<button class="btn-icon" title="SuperAdmin: acceso a todas las clínicas" disabled><i class="fas fa-hospital text-muted"></i></button>`;
            } else if (isDoctorUser) {
                clinicsBtn = `<button class="btn-icon" title="Clínicas derivadas de la asignación de médico" disabled><i class="fas fa-hospital text-muted"></i></button>`;
            } else {
                clinicsBtn = `<button class="btn-icon" onclick="openClinicsModal(${u.SecurityUserId},'${escaped}')" title="Clínicas asignadas"><i class="fas fa-hospital text-info"></i></button>`;
            }
            return `<tr data-id="${u.SecurityUserId}">
                <td>${u.SecurityUserId}</td>
                <td>
                    <div class="user-info">
                        <img src="https://ui-avatars.com/api/?name=${initials}&background=10b981&color=fff" alt="${escapeHtml(u.UserName ?? '')}">
                        <div>
                            <div class="user-name">${escapeHtml(u.UserName ?? '')}</div>
                            <div class="user-email">${escapeHtml(u.UserEmail ?? '')}</div>
                        </div>
                    </div>
                </td>
                <td>${u.UserIdNumber > 0 ? u.UserIdNumber : '—'}</td>
                <td><span class="role-badge ${badgeClass}">${escapeHtml(u.RoleName ?? '—')}</span></td>
                <td>${actBadge}</td>
                <td><span class="status-badge ${statusClass}"><i class="fas fa-circle"></i> ${statusLabel}</span></td>
                <td class="text-end">
                    <div class="action-buttons">
                        ${userPerms.canEdit ? resendBtn : ''}
                        ${userPerms.canEdit ? clinicsBtn : ''}
                        ${userPerms.canEdit   ? `<button class="btn-icon" onclick="editUser(${u.SecurityUserId})" title="Editar"><i class="fas fa-edit"></i></button>` : ''}
                        ${userPerms.canDelete ? `<button class="btn-icon" onclick="confirmDelete(${u.SecurityUserId},'${escaped}')" title="Eliminar"><i class="fas fa-trash text-danger"></i></button>` : ''}
                    </div>
                </td>
            </tr>`;
        }).join('');

        renderPagination();
    }

    function renderPagination() {
        const total      = filteredUsers.length;
        const totalPages = Math.ceil(total / PAGE_SIZE);
        const pag        = document.getElementById('pagination');
        const info       = document.getElementById('paginationInfo');

        if (total === 0) { info.textContent = ''; pag.innerHTML = ''; return; }

        const start = (currentPage - 1) * PAGE_SIZE + 1;
        const end   = Math.min(currentPage * PAGE_SIZE, total);
        info.textContent = `Mostrando ${start}–${end} de ${total}`;

        if (totalPages <= 1) { pag.innerHTML = ''; return; }

        const pages  = new Set([1, totalPages]);
        for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) pages.add(i);
        const sorted = [...pages].sort((a, b) => a - b);

        let html = `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="goToPage(${currentPage - 1});return false;">&lsaquo;</a></li>`;
        let prev = 0;
        for (const p of sorted) {
            if (p - prev > 1) html += `<li class="page-item disabled"><span class="page-link">&hellip;</span></li>`;
            html += `<li class="page-item ${p === currentPage ? 'active' : ''}">
                <a class="page-link" href="#" onclick="goToPage(${p});return false;">${p}</a></li>`;
            prev = p;
        }
        html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
            <a class="page-link" href="#" onclick="goToPage(${currentPage + 1});return false;">&rsaquo;</a></li>`;
        pag.innerHTML = html;
    }

    function goToPage(page) {
        const totalPages = Math.max(1, Math.ceil(filteredUsers.length / PAGE_SIZE));
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        renderTable();
    }

    function applyFilters() {
        const q = (document.getElementById('searchInput').value ?? '').trim().toLowerCase();
        filteredUsers = q
            ? allUsers.filter(u => {
                const name   = (u.UserName ?? '').toLowerCase();
                const email  = (u.UserEmail ?? '').toLowerCase();
                const idNum  = u.UserIdNumber > 0 ? String(u.UserIdNumber) : '';
                const role   = (u.RoleName ?? '').toLowerCase();
                const stat   = u.StatusId === 1 ? 'activo' : 'inactivo';
                const act    = u.IsActivated ? 'activado' : 'pendiente';
                return name.includes(q) || email.includes(q) || idNum.includes(q) ||
                       role.includes(q) || stat.includes(q) || act.includes(q);
            })
            : [...allUsers];
        currentPage = 1;
        renderTable();
    }

    function clearSearch() {
        document.getElementById('searchInput').value = '';
        applyFilters();
    }

    function showToast(message, success) {
        const el = document.getElementById('toast');
        el.classList.remove('bg-success', 'bg-danger');
        el.classList.add(success ? 'bg-success' : 'bg-danger');
        document.getElementById('toastMessage').textContent = message;
        toast.show();
    }

    function onRoleChange() {
        const sel  = document.getElementById('securityRoleId');
        const name = (sel.options[sel.selectedIndex]?.dataset.name ?? '').toLowerCase();
        const isDoctorRole = name.includes('médico') || name.includes('medico') || name.includes('doctor');
        document.getElementById('doctorRow').style.display = isDoctorRole ? '' : 'none';
        if (!isDoctorRole) document.getElementById('doctorId').value = '';
    }

    function openModal() {
        document.getElementById('securityUserId').value = '0';
        document.getElementById('userName').value       = '';
        document.getElementById('userEmail').value      = '';
        document.getElementById('userIdNumber').value   = '';
        document.getElementById('securityRoleId').value = document.getElementById('securityRoleId').options[0]?.value ?? '';
        document.getElementById('userStatusId').value   = '1';
        document.getElementById('doctorId').value       = '';
        document.getElementById('modalTitle').textContent = 'Nuevo Usuario';
        document.getElementById('newUserNotice').style.display = '';
        document.getElementById('btnSaveText').textContent     = 'Crear y enviar invitación';
        document.getElementById('btnSaveIcon').innerHTML       = '<i class="fas fa-paper-plane me-1"></i>';
        onRoleChange();
        clearValidation();
        userModal.show();
        setTimeout(() => document.getElementById('userName').focus(), 300);
    }

    function editUser(id) {
        const u = allUsers.find(x => x.SecurityUserId === id);
        if (!u) return;
        document.getElementById('securityUserId').value = u.SecurityUserId;
        document.getElementById('userName').value       = u.UserName ?? '';
        document.getElementById('userEmail').value      = u.UserEmail ?? '';
        document.getElementById('userIdNumber').value   = u.UserIdNumber > 0 ? u.UserIdNumber : '';
        document.getElementById('securityRoleId').value = u.SecurityRoleId;
        document.getElementById('userStatusId').value   = u.StatusId;
        document.getElementById('doctorId').value       = u.DoctorId ?? '';
        document.getElementById('modalTitle').textContent = 'Editar Usuario';
        document.getElementById('newUserNotice').style.display = 'none';
        document.getElementById('btnSaveText').textContent     = 'Guardar cambios';
        document.getElementById('btnSaveIcon').innerHTML       = '<i class="fas fa-save me-1"></i>';
        onRoleChange();
        clearValidation();
        userModal.show();
    }

    function clearValidation() {
        ['userName', 'userEmail'].forEach(id => {
            document.getElementById(id).classList.remove('is-invalid');
        });
    }

    function saveUser() {
        clearValidation();
        const id    = parseInt(document.getElementById('securityUserId').value);
        const name  = document.getElementById('userName').value.trim();
        const email = document.getElementById('userEmail').value.trim();
        let valid = true;

        if (!name) {
            document.getElementById('userName').classList.add('is-invalid');
            document.getElementById('nameError').textContent = 'El nombre es requerido.';
            valid = false;
        }
        if (!email) {
            document.getElementById('userEmail').classList.add('is-invalid');
            document.getElementById('emailError').textContent = 'El correo es requerido.';
            valid = false;
        }
        if (!valid) return;

        const roleId      = parseInt(document.getElementById('securityRoleId').value);
        const statusId    = parseInt(document.getElementById('userStatusId').value);
        const doctorIdRaw = document.getElementById('doctorId').value;

        const payload = {
            securityUserId: id,
            userName:       name,
            userEmail:      email,
            userIdNumber:   parseInt(document.getElementById('userIdNumber').value) || 0,
            securityRoleId: roleId,
            statusId:       statusId,
            doctorId:       doctorIdRaw ? parseInt(doctorIdRaw) : null,
        };

        document.getElementById('btnSave').disabled = true;

        fetch('/Admin/User/Save', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(payload)
        })
        .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e)))
        .then(data => {
            userModal.hide();

            const newId     = id === 0 ? data.securityUserId : id;
            const roleEntry = allRoles.find(r => r.SecurityRoleId === roleId);
            const docEntry  = allDoctors.find(d => d.DoctorId === payload.doctorId);

            const newDoc = {
                SecurityUserId: newId,
                UserName:       name,
                UserEmail:      email,
                UserIdNumber:   payload.userIdNumber,
                SecurityRoleId: roleId,
                RoleName:       roleEntry?.RoleName ?? null,
                IsSuperAdmin:   roleEntry?.IsSuperAdmin ?? false,
                StatusId:       statusId,
                IsActivated:    id !== 0 ? (allUsers.find(x => x.SecurityUserId === id)?.IsActivated ?? false) : false,
                DoctorId:       payload.doctorId ?? null,
                DoctorName:     docEntry?.DoctorName ?? null,
            };

            if (id === 0) {
                allUsers.push(newDoc);
                showToast('Usuario creado. Se envió un correo de activación.', true);
            } else {
                const idx = allUsers.findIndex(x => x.SecurityUserId === id);
                if (idx >= 0) allUsers[idx] = newDoc;
                showToast('Usuario actualizado correctamente.', true);
            }
            applyFilters();
        })
        .catch(err => showToast(err?.message ?? 'Error al guardar el usuario.', false))
        .finally(() => { document.getElementById('btnSave').disabled = false; });
    }

    function resendActivation(id, name) {
        if (!confirm(`¿Reenviar el correo de activación a ${name}?`)) return;
        fetch('/Admin/User/ResendActivation', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(id)
        })
        .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e)))
        .then(data => showToast(data.message ?? 'Correo reenviado correctamente.', true))
        .catch(err => showToast(err?.message ?? 'Error al reenviar el correo.', false));
    }

    function confirmDelete(id, name) {
        pendingDeleteId = id;
        document.getElementById('deleteName').textContent = name;
        deleteModal.show();
    }

    function deleteUser() {
        document.getElementById('btnDelete').disabled = true;
        fetch('/Admin/User/Delete', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(pendingDeleteId)
        })
        .then(r => {
            if (!r.ok) return Promise.reject();
            deleteModal.hide();
            const idx = allUsers.findIndex(x => x.SecurityUserId === pendingDeleteId);
            if (idx >= 0) allUsers.splice(idx, 1);
            applyFilters();
            showToast('Usuario eliminado correctamente.', true);
        })
        .catch(() => showToast('Error al eliminar el usuario.', false))
        .finally(() => { document.getElementById('btnDelete').disabled = false; });
    }

    function openClinicsModal(securityUserId, userName) {
        document.getElementById('clinicsUserId').value = securityUserId;
        document.getElementById('clinicsModalTitle').textContent = `Clínicas — ${userName}`;
        document.getElementById('clinicsLoading').classList.remove('d-none');
        document.getElementById('clinicsChecks').classList.add('d-none');
        document.getElementById('clinicsError').classList.add('d-none');
        document.getElementById('clinicsSearch').value = '';
        document.getElementById('btnSaveClinics').disabled = false;
        userClinicsCache = [];
        clinicsModal.show();

        fetch(`/Admin/User/GetUserClinics?securityUserId=${securityUserId}`)
            .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e.message ?? 'Error al cargar.')))
            .then(data => {
                userClinicsCache = data ?? [];
                renderClinicsChecks();
                document.getElementById('clinicsLoading').classList.add('d-none');
                document.getElementById('clinicsChecks').classList.remove('d-none');
            })
            .catch(err => {
                document.getElementById('clinicsLoading').classList.add('d-none');
                const errEl = document.getElementById('clinicsError');
                errEl.textContent = typeof err === 'string' ? err : 'Error al cargar las clínicas.';
                errEl.classList.remove('d-none');
            });
    }

    function renderClinicsChecks() {
        const q = (document.getElementById('clinicsSearch').value ?? '').trim().toLowerCase();
        const container = document.getElementById('clinicsChecks');
        const filtered = q
            ? userClinicsCache.filter(c => (c.clinicName ?? '').toLowerCase().includes(q) ||
                                            (c.stateName  ?? '').toLowerCase().includes(q))
            : userClinicsCache;

        if (filtered.length === 0) {
            container.innerHTML = '<div class="text-center text-muted py-3">No hay clínicas activas.</div>';
            return;
        }

        container.innerHTML = filtered.map(c => `
            <div class="form-check py-1">
                <input class="form-check-input clinic-check" type="checkbox"
                       id="chkClinic${c.clinicId}" value="${c.clinicId}"
                       ${c.isAssigned ? 'checked' : ''}>
                <label class="form-check-label d-flex justify-content-between" for="chkClinic${c.clinicId}">
                    <span>${escapeHtml(c.clinicName ?? '')}</span>
                    <small class="text-muted">${escapeHtml(c.stateName ?? '')}</small>
                </label>
            </div>
        `).join('');

        container.querySelectorAll('.clinic-check').forEach(chk => {
            chk.addEventListener('change', () => {
                const id = parseInt(chk.value);
                const entry = userClinicsCache.find(c => c.clinicId === id);
                if (entry) entry.isAssigned = chk.checked;
            });
        });
    }

    function filterClinicsList() {
        renderClinicsChecks();
    }

    function saveUserClinics() {
        const userId = parseInt(document.getElementById('clinicsUserId').value);
        const clinicIds = userClinicsCache.filter(c => c.isAssigned).map(c => c.clinicId);

        document.getElementById('btnSaveClinics').disabled = true;
        fetch('/Admin/User/SaveUserClinics', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ securityUserId: userId, clinicIds })
        })
        .then(r => r.ok ? null : r.json().then(e => Promise.reject(e.message ?? 'Error al guardar.')))
        .then(() => {
            clinicsModal.hide();
            showToast('Clínicas asignadas correctamente.', true);
        })
        .catch(err => showToast(typeof err === 'string' ? err : 'Error al guardar las clínicas.', false))
        .finally(() => { document.getElementById('btnSaveClinics').disabled = false; });
    }

    function escapeHtml(text) {
        const d = document.createElement('div');
        d.textContent = text ?? '';
        return d.innerHTML;
    }

    applyFilters();
</script>
}
