    /* ── Sanitización de texto en el modal (mayúsculas, sin acentos excepto Ñ) ── */
    (function bindRegPatInputs() {
        const ACCENT = {
            'á':'A','à':'A','ä':'A','â':'A','ã':'A','Á':'A','À':'A','Ä':'A','Â':'A','Ã':'A',
            'é':'E','è':'E','ë':'E','ê':'E','É':'E','È':'E','Ë':'E','Ê':'E',
            'í':'I','ì':'I','ï':'I','î':'I','Í':'I','Ì':'I','Ï':'I','Î':'I',
            'ó':'O','ò':'O','ö':'O','ô':'O','õ':'O','Ó':'O','Ò':'O','Ö':'O','Ô':'O','Õ':'O',
            'ú':'U','ù':'U','ü':'U','û':'U','Ú':'U','Ù':'U','Ü':'U','Û':'U',
            'ñ':'Ñ'
        };
        function sanitize(val) {
            return val.split('').map(c => ACCENT[c] ?? c).join('')
                .toUpperCase().replace(/[^A-ZÑ0-9 .,\-#()/':]/g, '');
        }
        document.querySelectorAll('#regPat_form .reg-text').forEach(el => {
            el.addEventListener('input', () => {
                const p = el.selectionStart; el.value = sanitize(el.value);
                try { el.setSelectionRange(p, p); } catch(_) {}
            });
            el.addEventListener('paste', e => {
                e.preventDefault();
                const raw = (e.clipboardData || window.clipboardData).getData('text') || '';
                el.value = sanitize(el.value.slice(0, el.selectionStart) + raw + el.value.slice(el.selectionEnd));
            });
        });
        document.querySelectorAll('#regPat_form .reg-phone').forEach(el => {
            const clean = v => v.replace(/[^0-9]/g, '');
            el.addEventListener('keypress', e => { if (!/\d/.test(e.key)) e.preventDefault(); });
            el.addEventListener('input',    () => { el.value = clean(el.value); });
            el.addEventListener('paste',    e => {
                e.preventDefault();
                el.value = clean((e.clipboardData || window.clipboardData).getData('text') || '');
            });
        });
        ['regPat_idNumber', 'regPat_guardianIdNumber'].forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            el.addEventListener('keypress', e => { if (!/\d/.test(e.key)) e.preventDefault(); });
            el.addEventListener('input',    () => { el.value = el.value.replace(/\D/g, '').slice(0, 9); });
            el.addEventListener('paste',    e => {
                e.preventDefault();
                el.value = (e.clipboardData.getData('text') || '').replace(/\D/g, '').slice(0, 9);
            });
        });
    })();

    function openRegisterPatient(appointmentId) {
        const loading = document.getElementById('regPat_loading');
        const form    = document.getElementById('regPat_form');
        const errMsg  = document.getElementById('regPat_errorMsg');
        loading.classList.remove('d-none');
        form.classList.add('d-none');
        errMsg.classList.add('d-none');
        document.getElementById('regPat_apptLabel').textContent = 'Cita #' + appointmentId;
        document.getElementById('regPat_appointmentId').value   = appointmentId;
        document.getElementById('regPat_saveBtn').disabled = false;

        const modal = new bootstrap.Modal(document.getElementById('registerPatientModal'));
        modal.show();

        fetch(`/Home/GetAppointmentDetail?appointmentId=${appointmentId}`)
            .then(r => r.ok ? r.json() : r.json().then(e => Promise.reject(e.message ?? 'Error')))
            .then(d => {
                const isMinor = d.patientTypeId === 2;

                // Limpiar estados inválidos previos
                document.querySelectorAll('#regPat_form .is-invalid').forEach(el => el.classList.remove('is-invalid'));

                document.getElementById('regPat_patientTypeId').value = d.patientTypeId;
                document.getElementById('regPat_patientId').value     = 0;

                document.getElementById('regPat_sectionTitle').textContent =
                    isMinor ? 'Datos del Menor' : 'Datos del Paciente';

                document.getElementById('regPat_idNumberGroup').classList.toggle('d-none', isMinor);
                document.getElementById('regPat_guardianSection').classList.toggle('d-none', !isMinor);
                ['regPat_phoneGroup','regPat_addressGroup','regPat_stateGroup','regPat_municipalityGroup']
                    .forEach(id => document.getElementById(id).classList.toggle('d-none', isMinor));

                // Datos del paciente / menor
                document.getElementById('regPat_name').value     = d.patientName ?? '';
                document.getElementById('regPat_idNumber').value = isMinor ? '' : (d.patientIdNumber || '');
                document.getElementById('regPat_sexId').value    = d.patientSexId || '';
                document.getElementById('regPat_birthdate').value =
                    d.patientBirthDate ? d.patientBirthDate.slice(0, 10) : '';
                document.getElementById('regPat_phone').value   = (d.patientPhone   ?? '').replace(/\D/g, '');
                document.getElementById('regPat_address').value = d.patientAddress  ?? '';
                loadRegMunicipalities(d.patientStateId || 0, 0);
                document.getElementById('regPat_stateId').value = d.patientStateId  || '';

                if (isMinor) {
                    document.getElementById('regPat_guardianName').value      = d.childGuardianName     ?? '';
                    document.getElementById('regPat_guardianIdNumber').value  = d.childGuardianIdNumber || '';
                    document.getElementById('regPat_guardianSexId').value     = d.childGuardianSexId    || '';
                    document.getElementById('regPat_guardianBirthdate').value =
                        d.childGuardianBirthDate ? d.childGuardianBirthDate.slice(0, 10) : '';
                    document.getElementById('regPat_guardianPhone').value   = (d.childGuardianPhone   ?? '').replace(/\D/g, '');
                    document.getElementById('regPat_guardianAddress').value = d.childGuardianAddress  ?? '';
                    loadRegGuardianMunicipalities(d.childGuardianStateId || 0, 0);
                    document.getElementById('regPat_guardianStateId').value = d.childGuardianStateId  || '';
                    const relSel = document.getElementById('regPat_relationshipId');
                    relSel.value = d.relationshipName
                        ? (allRegRelationships.find(r => r.RelationshipName === d.relationshipName)?.RelationshipId ?? '') : '';
                }

                loading.classList.add('d-none');
                form.classList.remove('d-none');
            })
            .catch(msg => {
                loading.innerHTML =
                    `<div class="alert alert-danger">${escHtml(typeof msg === 'string' ? msg : 'Error al cargar la cita.')}</div>`;
            });
    }

