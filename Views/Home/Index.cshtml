    async function confirmRegPatient() {
        const btn     = document.getElementById('confirmRegPatBtn');
        const errMsg  = document.getElementById('regPat_errorMsg');
        const isMinor = parseInt(document.getElementById('regPat_patientTypeId').value) === 2;
        btn.disabled  = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Guardando...';

        const g = id => document.getElementById(id);
        const intVal  = id => parseInt(g(id).value)              || 0;
        const strVal  = id => g(id).value.trim();
        const phoneOf = id => parseInt(g(id).value.replace(/\D/g, '')) || 0;

        const apptId = parseInt(g('regPat_appointmentId').value) || 0;

        const payload = {
            appointmentId: apptId,
            patient: {
                patientId:        parseInt(g('regPat_patientId').value) || 0,
                patientIdNumber:  isMinor ? null : (parseInt(g('regPat_idNumber').value) || null),
                patientName:      strVal('regPat_name'),
                sexId:            intVal('regPat_sexId'),
                patientBirthdate: strVal('regPat_birthdate'),
                patientAddress:   isMinor ? null : strVal('regPat_address'),
                municipalityId:   isMinor ? 0    : intVal('regPat_municipalityId'),
                patientMainPhone: isMinor ? 0    : phoneOf('regPat_phone')
            },
            guardian: isMinor ? {
                patientId:        0,
                patientIdNumber:  parseInt(g('regPat_guardianIdNumber').value) || null,
                patientName:      strVal('regPat_guardianName'),
                sexId:            intVal('regPat_guardianSexId'),
                patientBirthdate: strVal('regPat_guardianBirthdate'),
                patientAddress:   strVal('regPat_guardianAddress'),
                municipalityId:   intVal('regPat_guardianMunicipalityId'),
                patientMainPhone: phoneOf('regPat_guardianPhone')
            } : null,
            relationshipId: isMinor ? intVal('regPat_relationshipId') : 0
        };

        try {
            const resp = await fetch('/Home/RegisterPatient', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload)
            });
            const result = await resp.json();
            bootstrap.Modal.getInstance(document.getElementById('confirmRegPatientModal')).hide();

            if (resp.ok) {
                bootstrap.Modal.getInstance(document.getElementById('registerPatientModal')).hide();
                // Marcar la cita como registrada en la lista local
                if (apptId > 0) {
                    const idx = allAppointments.findIndex(a => a.appointmentId === apptId);
                    if (idx !== -1) {
                        allAppointments[idx].isRegistered = true;
                        renderDashTable();
                    }
                }
                showDashToast('Paciente registrado exitosamente.', true);
            } else {
                errMsg.textContent = result.message ?? 'Error al registrar el paciente.';
                errMsg.classList.remove('d-none');
            }
        } catch {
            errMsg.textContent = 'Error de conexión. Intente nuevamente.';
            errMsg.classList.remove('d-none');
        } finally {
            btn.disabled  = false;
            btn.innerHTML = '<i class="fas fa-check me-1"></i> Sí, registrar';
        }
    }

    function showDashToast(message, success) {
        const el = document.getElementById('dashToast');
        el.classList.remove('bg-success', 'bg-danger');
        el.classList.add(success ? 'bg-success' : 'bg-danger');
        document.getElementById('dashToastMessage').textContent = message;
        new bootstrap.Toast(el, { delay: 3500 }).show();
    }

