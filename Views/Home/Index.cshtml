    function deleteAppointment() {
        const btn = document.getElementById('btnConfirmDeleteAppt');
        btn.disabled = true;
        fetch('/Home/DeleteAppointment', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(pendingDeleteAppointmentId)
        })
        .then(r => {
            if (!r.ok) return r.json().then(e => Promise.reject(e.message ?? 'Error'));
            bootstrap.Modal.getInstance(document.getElementById('deleteAppointmentModal')).hide();
            const idx = allAppointments.findIndex(a => a.appointmentId === pendingDeleteAppointmentId);
            if (idx >= 0) allAppointments.splice(idx, 1);
            applyDashFilters();
            showDashToast('Cita eliminada correctamente.', true);
        })
        .catch(msg => showDashToast(typeof msg === 'string' ? msg : 'Error al eliminar la cita.', false))
        .finally(() => { btn.disabled = false; });
    }

    async function openEyeDetail(appointmentId, isRegistered) {
