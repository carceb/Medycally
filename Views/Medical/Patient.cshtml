@model Medycally.Models.AppointmentDetailModel
@{
    ViewData["Title"] = "Atención al Paciente";
    var history  = ViewBag.History  as List<Medycally.Models.MedicalAttentionModel> ?? [];
    var existing = ViewBag.Existing as Medycally.Models.MedicalAttentionModel;
    var isMinor  = Model.PatientTypeId == 2;
}

<!-- Back link -->
<div class="mb-3">
    <a href="/Medical/Index" class="text-decoration-none text-muted">
        <i class="fas fa-arrow-left me-1"></i>Volver a la Cola
    </a>
</div>

<!-- Status banner -->
@if (Model.AppointmentStatusId == 4)
{
    <div class="alert alert-info d-flex align-items-center py-2 mb-3">
        <i class="fas fa-user-clock me-2"></i>
        <strong>En Atención</strong> &nbsp;— cita #@Model.AppointmentId
    </div>
}

<div class="row g-4">

    <!-- ======================== LEFT: Patient + Appointment info ======================== -->
    <div class="col-lg-4">

        <!-- Patient card -->
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-header bg-primary text-white py-2">
                <i class="fas fa-user me-2"></i>Datos del Paciente
            </div>
            <div class="card-body">
                <div class="mb-2">
                    <span class="fw-bold fs-5">@(!string.IsNullOrEmpty(Model.PatientName) ? Model.PatientName : "—")</span>
                    @if (isMinor)
                    {
                        <span class="badge bg-warning text-dark ms-2">Menor</span>
                    }
                </div>
                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted pe-2">Cédula</td>
                        <td>@(Model.PatientIdNumber > 0 ? $"V-{Model.PatientIdNumber}" : "Sin cédula")</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Edad</td>
                        <td>@Model.PatientAge años</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Sexo</td>
                        <td>@(Model.PatientSexName ?? "—")</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.PatientPhone))
                    {
                        <tr>
                            <td class="text-muted pe-2">Teléfono</td>
                            <td>@Model.PatientPhone</td>
                        </tr>
                    }
                    @if (!string.IsNullOrEmpty(Model.PatientAddress))
                    {
                        <tr>
                            <td class="text-muted pe-2">Dirección</td>
                            <td>@Model.PatientAddress</td>
                        </tr>
                    }
                    @if (Model.PatientBirthDate.HasValue)
                    {
                        <tr>
                            <td class="text-muted pe-2">Nacimiento</td>
                            <td>@Model.PatientBirthDate.Value.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </table>

                @if (isMinor && !string.IsNullOrEmpty(Model.ChildGuardianName))
                {
                    <hr class="my-2" />
                    <div class="small text-muted mb-1"><i class="fas fa-user-friends me-1"></i>Representante</div>
                    <div class="fw-semibold">@Model.ChildGuardianName</div>
                    @if (!string.IsNullOrEmpty(Model.RelationshipName))
                    {
                        <div class="small text-muted">@Model.RelationshipName</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ChildGuardianPhone))
                    {
                        <div class="small"><i class="fas fa-phone me-1"></i>@Model.ChildGuardianPhone</div>
                    }
                }
            </div>
        </div>

        <!-- Appointment card -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white py-2">
                <i class="fas fa-calendar-check me-2"></i>Datos de la Cita
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0 small">
                    <tr>
                        <td class="text-muted pe-2">Especialidad</td>
                        <td class="fw-semibold">@(Model.SpecialtyName ?? "—")</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Médico</td>
                        <td>@(Model.DoctorName ?? "—")</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Fecha</td>
                        <td>@Model.AppointmentDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <td class="text-muted pe-2">Hora</td>
                        <td>@(Model.AppointmentTime ?? "—")</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.ReasonName))
                    {
                        <tr>
                            <td class="text-muted pe-2">Motivo</td>
                            <td>@Model.ReasonName</td>
                        </tr>
                    }
                </table>

                @if (!string.IsNullOrEmpty(Model.Symptoms))
                {
                    <div class="mt-2 p-2 bg-light rounded small">
                        <div class="text-muted mb-1"><i class="fas fa-comment-medical me-1"></i>Síntomas referidos</div>
                        <div>@Model.Symptoms</div>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ======================== RIGHT: History + New Attention ======================== -->
    <div class="col-lg-8">

        <!-- Medical History -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-2 d-flex align-items-center justify-content-between">
                <span><i class="fas fa-notes-medical me-2 text-primary"></i>Historia Médica</span>
                <span class="badge bg-primary rounded-pill">@history.Count</span>
            </div>
            <div class="card-body p-0">
                @if (history.Count == 0)
                {
                    <div class="text-center py-4 text-muted small">
                        <i class="fas fa-file-medical fa-2x mb-2 opacity-25 d-block"></i>
                        Sin atenciones previas registradas.
                    </div>
                }
                else
                {
                    <div class="accordion accordion-flush" id="historyAccordion">
                        @for (int i = 0; i < history.Count; i++)
                        {
                            var h     = history[i];
                            var colId = $"hist-{i}";
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button @(i > 0 ? "collapsed" : "")"
                                            type="button" data-bs-toggle="collapse"
                                            data-bs-target="#@colId">
                                        <div class="d-flex w-100 align-items-center gap-3 flex-wrap">
                                            <span class="fw-semibold">
                                                @h.AttentionDate.ToString("dd/MM/yyyy")
                                            </span>
                                            @if (!string.IsNullOrEmpty(h.PatientName))
                                            {
                                                <span class="badge bg-warning text-dark">@h.PatientName</span>
                                            }
                                            <span class="text-muted small">
                                                @(h.SpecialtyName ?? "") &nbsp;·&nbsp; @(h.DoctorName ?? "")
                                            </span>
                                        </div>
                                    </button>
                                </h2>
                                <div id="@colId" class="accordion-collapse collapse @(i == 0 ? "show" : "")">
                                    <div class="accordion-body small">
                                        @if (!string.IsNullOrEmpty(h.Symptoms))
                                        {
                                            <div class="mb-2">
                                                <span class="text-muted">Síntomas:&nbsp;</span>@h.Symptoms
                                            </div>
                                        }
                                        <div class="mb-2">
                                            <div class="text-muted fw-semibold mb-1">Diagnóstico</div>
                                            <div class="p-2 bg-light rounded">@h.Diagnosis</div>
                                        </div>
                                        <div class="mb-2">
                                            <div class="text-muted fw-semibold mb-1">Tratamiento</div>
                                            <div class="p-2 bg-light rounded">@h.Treatment</div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(h.Notes))
                                        {
                                            <div>
                                                <div class="text-muted fw-semibold mb-1">Notas</div>
                                                <div class="p-2 bg-light rounded">@h.Notes</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- New / Edit Attention form -->
        <div class="card shadow-sm border-0">
            <div class="card-header py-2 bg-success text-white">
                <i class="fas fa-file-medical-alt me-2"></i>
                @(existing != null ? "Editar Atención" : "Nueva Atención")
            </div>
            <div class="card-body">
                <input type="hidden" id="attentionId"   value="@(existing?.AttentionId ?? 0)" />
                <input type="hidden" id="appointmentId" value="@Model.AppointmentId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Diagnóstico <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="txtDiagnosis" rows="4"
                              placeholder="Descripción del diagnóstico médico...">@(existing?.Diagnosis ?? "")</textarea>
                    <div class="invalid-feedback" id="diagnosisError"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Tratamiento <span class="text-danger">*</span>
                    </label>
                    <textarea class="form-control" id="txtTreatment" rows="4"
                              placeholder="Plan de tratamiento indicado...">@(existing?.Treatment ?? "")</textarea>
                    <div class="invalid-feedback" id="treatmentError"></div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notas adicionales</label>
                    <textarea class="form-control" id="txtNotes" rows="2"
                              placeholder="Observaciones, indicaciones adicionales...">@(existing?.Notes ?? "")</textarea>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <button type="button" class="btn btn-success px-4" id="btnSaveAttention"
                            onclick="saveAttention()">
                        <i class="fas fa-save me-2"></i>Guardar Atención
                    </button>
                    <span id="saveStatus" class="small text-muted"></span>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .accordion-button:not(.collapsed) { background: #f0f9ff; color: #0a58ca; }
</style>

@section Scripts {
<script>
    async function saveAttention() {
        const diagnosis = document.getElementById('txtDiagnosis').value.trim();
        const treatment = document.getElementById('txtTreatment').value.trim();
        let valid = true;

        document.getElementById('txtDiagnosis').classList.remove('is-invalid');
        document.getElementById('txtTreatment').classList.remove('is-invalid');

        if (!diagnosis) {
            document.getElementById('txtDiagnosis').classList.add('is-invalid');
            document.getElementById('diagnosisError').textContent = 'El diagnóstico es requerido.';
            valid = false;
        }
        if (!treatment) {
            document.getElementById('txtTreatment').classList.add('is-invalid');
            document.getElementById('treatmentError').textContent = 'El tratamiento es requerido.';
            valid = false;
        }
        if (!valid) return;

        const payload = {
            attentionId:   parseInt(document.getElementById('attentionId').value),
            appointmentId: parseInt(document.getElementById('appointmentId').value),
            diagnosis:     diagnosis,
            treatment:     treatment,
            notes:         document.getElementById('txtNotes').value.trim() || null
        };

        const btn = document.getElementById('btnSaveAttention');
        btn.disabled = true;

        try {
            const res = await fetch('/Medical/SaveAttention', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(payload)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message ?? 'Error al guardar.');

            document.getElementById('attentionId').value = data.attentionId;
            document.getElementById('saveStatus').innerHTML =
                `<i class="fas fa-check-circle text-success me-1"></i>Guardado correctamente. Actualizando...`;

            setTimeout(() => { window.location.reload(); }, 1500);
        } catch (e) {
            document.getElementById('saveStatus').innerHTML =
                `<i class="fas fa-exclamation-circle text-danger me-1"></i>${e.message}`;
        } finally {
            btn.disabled = false;
        }
    }
</script>
}
