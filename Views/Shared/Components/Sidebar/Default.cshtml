@model List<Medycally.Models.NavigationModuleModel>
@{
    var currentPath = ViewData["CurrentPath"] as string ?? "";

    Func<string?, bool> IsActive = url =>
        !string.IsNullOrEmpty(url)
        && (currentPath.Equals(url, StringComparison.OrdinalIgnoreCase)
            || currentPath.StartsWith(url + "/", StringComparison.OrdinalIgnoreCase));

    var topLevel = Model.Where(m => m.ParentSecurityModuleId == null).ToList();
}

@foreach (var parent in topLevel)
{
    var children = Model.Where(m => m.ParentSecurityModuleId == parent.SecurityModuleId).ToList();

    if (children.Count == 0)
    {
        var isActive = IsActive(parent.ModuleUrl);
        <li class="sidebar-item">
            <a href="@parent.ModuleUrl" class="sidebar-link @(isActive ? "active" : "")">
                <i class="fas @(parent.ModuleIcon ?? "fa-circle")"></i>
                <span>@parent.ModuleName</span>
            </a>
        </li>
    }
    else
    {
        var isParentActive = children.Any(c => IsActive(c.ModuleUrl));
        var menuId = $"sidebarMenu_{parent.SecurityModuleId}";
        <li class="sidebar-item">
            <a class="sidebar-link sidebar-link-parent @(isParentActive ? "active" : "")"
               data-bs-toggle="collapse" data-bs-target="#@menuId"
               href="#" role="button"
               aria-expanded="@(isParentActive ? "true" : "false")">
                <i class="fas @(parent.ModuleIcon ?? "fa-circle")"></i>
                <span>@parent.ModuleName</span>
                <i class="fas fa-chevron-right sidebar-chevron"></i>
            </a>
            <ul class="sidebar-dropdown collapse @(isParentActive ? "show" : "")" id="@menuId">
                @foreach (var child in children)
                {
                    var isChildActive = IsActive(child.ModuleUrl);
                    <li class="sidebar-item">
                        <a href="@child.ModuleUrl"
                           class="sidebar-link @(isChildActive ? "active" : "")">
                            <i class="fas @(child.ModuleIcon ?? "fa-circle")"></i>
                            <span>@child.ModuleName</span>
                        </a>
                    </li>
                }
            </ul>
        </li>
    }
}
