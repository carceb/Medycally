        const phone       = isMinor ? true : regPatRequired('regPat_phone',          'Teléfono');
        const address     = isMinor ? true : regPatRequired('regPat_address',        'Dirección');
        const stateId     = isMinor ? true : regPatRequired('regPat_stateId',        'Estado');
        const municipalId = isMinor ? true : regPatRequired('regPat_municipalityId', 'Municipio');
        const idNumber    = isMinor ? true : regPatRequired('regPat_idNumber', 'Cédula');

        let gName, gSex, gBirth, gPhone, gAddress, gState, gMun, relId;
        if (isMinor) {
            gName    = regPatRequired('regPat_guardianName',           'Nombre del Representante');
