document.getElementById('btnConfirmSave').addEventListener('click', async function () {
    const btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Guardando...';

    const isMinor    = state.patientType === 'minor';
    const isExisting = state.isExisting  === 'yes';
    const slot       = state.selectedSlot;

    const symptoms = document.getElementById('txtSymptoms').value.trim() || '';
    const reasonId = parseInt(document.getElementById('selReason').value) || 0;

    const payload = {
        appointmentId       : 0,
        clinicId            : parseInt(state.clinicId),
        patientTypeId       : isMinor ? 2 : 1,
        specialtyDoctorId   : slot.specialtyDoctorId,
        appointmentDate     : slot.dateISO + 'T' + slot.startTime,
        symptoms,
        reasonId,
        appointmentStatusId : 0
    };

    if (isExisting) {
        payload.patientId               = parseInt(state.patientId) > 0 ? parseInt(state.patientId) : null;
        payload.patientName             = state.patientName;
        payload.patientAge              = parseInt(state.age) || 0;
        payload.sexId                   = parseInt(state.sexId) || 0;
        payload.patientPhone            = null;
        payload.patientAddress          = null;
        payload.patientStateId          = 0;
        payload.patientBirthDate        = null;
        if (isMinor) {
            payload.patientIdNumber         = 0;
            payload.childGuardianIdNumber   = parseInt(state.childGuardianIdNumber) || 0;
            payload.childGuardianName       = state.childGuardianName || 'N/A';
            payload.relationshipId          = parseInt(state.relationshipId) || 1;
            payload.childGuardianPhone      = null;
            payload.childGuardianAddress    = null;
            payload.childGuardianStateId    = 0;
            payload.childGuardianBirthDate  = null;
            payload.childGuardianSexId      = 0;
        } else {
            payload.patientIdNumber         = parseInt(state.idNumber) || 0;
            payload.childGuardianIdNumber   = 0;
            payload.childGuardianName       = 'N/A';
            payload.relationshipId          = 1;
            payload.childGuardianPhone      = null;
            payload.childGuardianAddress    = null;
            payload.childGuardianStateId    = 0;
            payload.childGuardianBirthDate  = null;
            payload.childGuardianSexId      = 0;
        }
    } else if (isMinor) {
        const minorBirthDate = document.getElementById('minorBirthDate').value;
        const rFecha = document.getElementById('guardianBirthDate').value;
        payload.patientName             = document.getElementById('minorName').value;
        payload.patientIdNumber         = 0;
        payload.patientAge              = minorBirthDate ? calcAge(minorBirthDate) : (rFecha ? calcAge(rFecha) : 0);
        payload.sexId                   = parseInt(document.getElementById('minorSex').value) || 0;
        payload.patientPhone            = null;
        payload.patientAddress          = null;
        payload.patientStateId          = 0;
        payload.patientBirthDate        = minorBirthDate || null;
        payload.childGuardianIdNumber   = parseInt(document.getElementById('guardianIdNumber').value) || 0;
        payload.childGuardianName       = document.getElementById('guardianName').value || 'N/A';
        payload.relationshipId          = parseInt(document.getElementById('guardianRelationship').value) || 1;
        payload.childGuardianPhone      = document.getElementById('guardianPhone').value || null;
        payload.childGuardianAddress    = document.getElementById('guardianAddress').value || null;
        payload.childGuardianStateId    = parseInt(document.getElementById('guardianState').value) || 0;
        payload.childGuardianBirthDate  = rFecha || null;
        payload.childGuardianSexId      = parseInt(document.getElementById('guardianSex').value) || 0;
    } else {
        const adultBirthDate = document.getElementById('adultBirthDate').value;
        payload.patientName             = document.getElementById('adultName').value;
        payload.patientIdNumber         = parseInt(document.getElementById('adultIdNumber').value) || 0;
        payload.patientAge              = adultBirthDate ? calcAge(adultBirthDate) : 0;
        payload.sexId                   = parseInt(document.getElementById('adultSex').value) || 0;
        payload.patientPhone            = document.getElementById('adultPhone').value || null;
        payload.patientAddress          = document.getElementById('adultAddress').value || null;
        payload.patientStateId          = parseInt(document.getElementById('adultState').value) || 0;
        payload.patientBirthDate        = adultBirthDate || null;
        payload.childGuardianIdNumber   = 0;
        payload.childGuardianName       = 'N/A';
        payload.relationshipId          = 1;
        payload.childGuardianPhone      = null;
        payload.childGuardianAddress    = null;
        payload.childGuardianStateId    = 0;
        payload.childGuardianBirthDate  = null;
        payload.childGuardianSexId      = 0;
    }

    try {
        const resp = await fetch('@Url.Action("Save", "Appointment")', {
            method  : 'POST',
            headers : { 'Content-Type': 'application/json' },
            body    : JSON.stringify(payload)
        });
        const result = await resp.json();

        bootstrap.Modal.getInstance(document.getElementById('modalConfirmSave')).hide();

        if (result.success) {
            document.getElementById('confirmResult').innerHTML =
                `<div class="alert alert-success d-flex align-items-center gap-2 mb-2">
                    <i class="fas fa-check-circle fs-5"></i>
                    <span>Cita registrada exitosamente. N° <strong>${result.appointmentId}</strong></span>
                </div>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <button type="button" class="btn-wz-next" onclick="goToStep('step-1')">
                        <i class="fas fa-arrow-left me-1"></i> Volver al Principio
                    </button>
                    <a href="@Url.Action("Landing","Home")" class="btn btn-outline-success rounded-pill px-4 fw-semibold" style="text-decoration:none;">
                        <i class="fas fa-globe me-1"></i> Mostrar sitio Web
                    </a>
                </div>`;
            document.getElementById('btnRegisterAppointment').classList.add('d-none');
        } else {
            document.getElementById('confirmResult').innerHTML =
                `<div class="alert alert-danger d-flex align-items-center gap-2 mb-0">
                    <i class="fas fa-exclamation-circle fs-5"></i>
                    <span>Error al registrar: ${result.error || 'Intente nuevamente.'}</span>
                </div>`;
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-save me-1"></i> Sí, registrar';
        }
    } catch {
        bootstrap.Modal.getInstance(document.getElementById('modalConfirmSave')).hide();
        document.getElementById('confirmResult').innerHTML =
            `<div class="alert alert-danger d-flex align-items-center gap-2 mb-0">
                <i class="fas fa-exclamation-circle fs-5"></i>
                <span>Error de conexión. Intente nuevamente.</span>
            </div>`;
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save me-1"></i> Sí, registrar';
    }
});
</script>
</body>
</html>
